  file_change {
    absolute_path_uri: "file:///src/components/AnalyticsCharts.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useMemo } from \'react\';\nimport { PatientRecord } from \'../types\';\nimport { calculateBatchSummary } from \'../utils/predictor\';\nimport { AreaChart, Area, BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer, PieChart, Pie, Cell } from \'recharts\';\nimport { ShieldAlert, Users, TrendingUp, HeartOff } from \'lucide-react\';\n\ninterface AnalyticsChartsProps {\n  records: PatientRecord[];\n}\n\nexport default function AnalyticsCharts({ records }: AnalyticsChartsProps) {\n  const summary = useMemo(() => calculateBatchSummary(records), [records]);\n\n  // Data mapping for Risk Level Pie Chart\n  const riskPieData = useMemo(() => {\n    return [\n      { name: \'Low Risk\', value: summary.riskDistribution.Low, color: \'#10b981\' },\n      { name: \'Moderate Risk\', value: summary.riskDistribution.Moderate, color: \'#f59e0b\' },\n      { name: \'High Risk\', value: summary.riskDistribution.High, color: \'#ef4444\' },\n      { name: \'Critical Risk\', value: summary.riskDistribution.Critical, color: \'#7f1d1d\' },\n    ].filter(item => item.value > 0);\n  }, [summary]);\n\n  // Data mapping for Chest Pain presentation types\n  const chestPainData = useMemo(() => {\n    return [\n      { name: \'TA (Typical Angina)\', count: summary.chestPainDistribution.TA, label: \'TA\' },\n      { name: \'ATA (Atypical Angina)\', count: summary.chestPainDistribution.ATA, label: \'ATA\' },\n      { name: \'NAP (Non-Anginal)\', count: summary.chestPainDistribution.NAP, label: \'NAP\' },\n      { name: \'ASY (Asymptomatic)\', count: summary.chestPainDistribution.ASY, label: \'ASY\' },\n    ];\n  }, [summary]);\n\n  // Data mapping for ST Slope risk trend\n  const slopeData = useMemo(() => {\n    return [\n      { name: \'Upsloping (Up)\', count: summary.stSlopeDistribution.Up, description: \'Up\' },\n      { name: \'Flat (Flat)\', count: summary.stSlopeDistribution.Flat, description: \'Flat\' },\n      { name: \'Downsloping (Down)\', count: summary.stSlopeDistribution.Down, description: \'Down\' },\n    ];\n  }, [summary]);\n\n  // Scatter/Bubble simulation plot - mapping Age to MaxHR, colored by risk level\n  const scatterSimulationData = useMemo(() => {\n    return records.map((rec) => {\n      const prob = rec.prediction?.heartDiseaseProbability ?? 0;\n      return {\n        name: rec.name,\n        age: rec.age,\n        maxHR: rec.maxHR,\n        probability: prob,\n        sex: rec.sex,\n        risk: rec.prediction?.riskLevel ?? \'Low\',\n        color: prob >= 75 ? \'#b91c1c\' : prob >= 50 ? \'#ef4444\' : prob >= 25 ? \'#f59e0b\' : \'#10b981\'\n      };\n    }).sort((a,b) => a.age - b.age);\n  }, [records]);\n\n  if (records.length === 0) {\n    return (\n      <div className=\"bg-white border border-slate-100 rounded-2xl p-12 text-center text-slate-500 flex flex-col items-center justify-center space-y-4 shadow-sm\">\n        <HeartOff className=\"w-12 h-12 text-slate-350 animate-pulse\" />\n        <div>\n          <h3 className=\"font-bold text-slate-700 text-lg\">No Cardiology Metadata Available</h3>\n          <p className=\"text-sm text-slate-400 mt-1 max-w-sm\">\n            Import patient mock details or use the Bulk Patient Scanner to automatically generate charts.\n          </p>\n        </div>\n      </div>\n    );\n  }\n\n  // Calculate clinical rates\n  const cardiacInvolvementRate = records.length > 0 \n    ? Math.round((summary.diseaseCount / records.length) * 100) \n    : 0;\n\n  return (\n    <div id=\"analytics-grid-workspace\" className=\"space-y-8\">\n      {/* Dynamic Metric Rows Cards */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\" id=\"kpi-scorecards\">\n        <div className=\"bg-white border border-slate-100 p-5 rounded-xl shadow-xs\">\n          <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Total Patient Pool</span>\n          <div className=\"flex items-baseline gap-2 mt-2\">\n            <span className=\"text-3xl font-black text-slate-800\">{summary.totalCount}</span>\n            <span className=\"text-xs text-slate-400 font-medium font-mono\">records loaded</span>\n          </div>\n          <div className=\"text-[11px] text-slate-405 mt-1 border-t border-slate-50 pt-2 flex items-center justify-between\">\n            <span>Male: {summary.genderDistribution.M}</span>\n            <span>Female: {summary.genderDistribution.F}</span>\n          </div>\n        </div>\n\n        <div className=\"bg-white border border-slate-100 p-5 rounded-xl shadow-xs\">\n          <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Mean Cohort Age</span>\n          <div className=\"flex items-baseline gap-2 mt-2\">\n            <span className=\"text-3xl font-black text-slate-800\">{summary.averageAge}</span>\n            <span className=\"text-xs text-slate-400 font-medium font-mono\">years old</span>\n          </div>\n          <div className=\"text-[11px] text-slate-500 mt-1 border-t border-slate-50 pt-2\">\n            Broad statistical span from Kaggle clinical registers.\n          </div>\n        </div>\n\n        <div className=\"bg-white border border-slate-100 p-5 rounded-xl shadow-xs relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 w-24 h-24 -mr-6 -mt-6 bg-red-50 rounded-full -z-10 opacity-30\"></div>\n          <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Identified High-Risk Cases</span>\n          <div className=\"flex items-baseline gap-2 mt-2\">\n            <span className=\"text-3xl font-black text-red-650\">{summary.diseaseCount}</span>\n            <span className=\"text-xs text-slate-400 font-medium font-mono\">(&gt;50% probability)</span>\n          </div>\n          <div className=\"text-[11px] text-red-600 mt-1 border-t border-slate-50 pt-2 flex items-center gap-1\">\n            <ShieldAlert className=\"w-3.5 h-3.5\" />\n            {cardiacInvolvementRate}% alert frequency rate\n          </div>\n        </div>\n\n        <div className=\"bg-white border border-slate-100 p-5 rounded-xl shadow-xs\">\n          <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Critical Stage Cohort</span>\n          <div className=\"flex items-baseline gap-2 mt-2\">\n            <span className=\"text-3xl font-black text-slate-800\">{summary.riskDistribution.Critical}</span>\n            <span className=\"text-xs text-slate-400 font-medium font-mono\">cardiac patients</span>\n          </div>\n          <div className=\"text-[11px] text-slate-500 mt-1 border-t border-slate-50 pt-2\">\n            Assigned priority clinical monitoring action status.\n          </div>\n        </div>\n      </div>\n\n      {/* Main Charts Partition Section */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\" id=\"charts-partition-container\">\n        \n        {/* Risk Category Distribution (Pie Chart) */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-xs flex flex-col h-[320px]\">\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider mb-2\">Overall Cardiac Risk Partitioning</h3>\n          <p className=\"text-xs text-slate-400 mb-4\">Percentage allocation of patients sorted into predictive risk thresholds.</p>\n          <div className=\"flex-1 min-h-0 flex items-center justify-between\">\n            <div className=\"w-1/2 h-full\">\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <PieChart>\n                  <Tooltip \n                    contentStyle={{ borderRadius: \'8px\', fontSize: \'12px\' }}\n                    formatter={(value) => [`${value} patient(s)`, \'Frequency\']}\n                  />\n                  <Pie\n                    data={riskPieData}\n                    cx=\"50%\"\n                    cy=\"48%\"\n                    innerRadius={55}\n                    outerRadius={80}\n                    paddingAngle={3}\n                    dataKey=\"value\"\n                  >\n                    {riskPieData.map((entry, idx) => (\n                      <Cell key={`cell-${idx}`} fill={entry.color} />\n                    ))}\n                  </Pie>\n                </PieChart>\n              </ResponsiveContainer>\n            </div>\n            \n            {/* Pie Chart Legend */}\n            <div className=\"w-1/2 space-y-2 pl-4 text-xs\">\n              {riskPieData.map((item, idx) => (\n                <div key={idx} className=\"flex items-center gap-2\">\n                  <span className=\"w-3 h-3 rounded-full shrink-0\" style={{ backgroundColor: item.color }}></span>\n                  <span className=\"text-slate-700 font-semibold\">{item.name}:</span>\n                  <span className=\"text-slate-500 font-mono font-bold ml-auto\">{item.value} ({Math.round(item.value / records.length * 100)}%)</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n        {/* Chest Pain Presentation Types Frequency */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-xs flex flex-col h-[320px]\">\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider mb-2\">Anginal Chest Pain Distribution</h3>\n          <p className=\"text-xs text-slate-400 mb-4\">Patient groupings mapped across the chest pain category system.</p>\n          <div className=\"flex-1 min-h-0\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <BarChart data={chestPainData} margin={{ top: 10, right: 10, left: -20, bottom: 5 }}>\n                <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"#f1f5f9\" />\n                <XAxis dataKey=\"name\" tick={{ fontSize: 10, fill: \'#64748b\' }} axisLine={false} tickLine={false} />\n                <YAxis tick={{ fontSize: 10, fill: \'#64748b\' }} axisLine={false} tickLine={false} />\n                <Tooltip contentStyle={{ borderRadius: \'8px\', fontSize: \'12px\' }} />\n                <Bar dataKey=\"count\" fill=\"#4f46e5\" radius={[4, 4, 0, 0]} name=\"Involved Patients\">\n                  {chestPainData.map((entry, index) => (\n                    <Cell key={`cell-${index}`} fill={entry.label === \'ASY\' ? \'#be123c\' : \'#4f46e5\'} />\n                  ))}\n                </Bar>\n              </BarChart>\n            </ResponsiveContainer>\n          </div>\n        </div>\n\n        {/* Diagnostic ST Slope Markers */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-xs flex flex-col h-[320px]\">\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider mb-2\">Electrocardiographic ST Slope Cohorts</h3>\n          <p className=\"text-xs text-slate-400 mb-4\">Distribution of exercise stress-test peak ST-segment slopes.</p>\n          <div className=\"flex-1 min-h-0\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <BarChart data={slopeData} layout=\"vertical\" margin={{ top: 10, right: 10, left: 10, bottom: 5 }}>\n                <CartesianGrid strokeDasharray=\"3 3\" horizontal={false} stroke=\"#f1f5f9\" />\n                <XAxis type=\"number\" tick={{ fontSize: 10 }} axisLine={false} tickLine={false} />\n                <YAxis dataKey=\"name\" type=\"category\" tick={{ fontSize: 10, fontWeight: 500 }} axisLine={false} tickLine={false} />\n                <Tooltip contentStyle={{ borderRadius: \'8px\', fontSize: \'12px\' }} />\n                <Bar dataKey=\"count\" fill=\"#3b82f6\" radius={[0, 4, 4, 0]} name=\"Involved Patients\">\n                  {slopeData.map((entry, index) => (\n                    <Cell key={`cell-${index}`} fill={entry.description === \'Up\' ? \'#10b981\' : entry.description === \'Flat\' ? \'#f59e0b\' : \'#ef4444\'} />\n                  ))}\n                </Bar>\n              </BarChart>\n            </ResponsiveContainer>\n          </div>\n        </div>\n\n        {/* Hemodynamic Analysis: Age vs Max Heart Rate Trend Area */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-xs flex flex-col h-[320px]\">\n          <h3 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider mb-2\">Hemodynamic Stress Tolerance Curve</h3>\n          <p className=\"text-xs text-slate-400 mb-4\">Patient age compared with maximum achieved heart rate. Downward trends represent potential chronotropic incompetence.</p>\n          <div className=\"flex-1 min-h-0\">\n            <ResponsiveContainer width=\"100%\" height=\"100%\">\n              <AreaChart data={scatterSimulationData} margin={{ top: 10, right: 15, left: -20, bottom: 5 }}>\n                <defs>\n                  <linearGradient id=\"colorMaxHR\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"5%\" stopColor=\"#ec4899\" stopOpacity={0.2}/>\n                    <stop offset=\"95%\" stopColor=\"#ec4899\" stopOpacity={0}/>\n                  </linearGradient>\n                </defs>\n                <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" />\n                <XAxis dataKey=\"age\" name=\"Age\" label={{ value: \'Age\', position: \'insideBottomRight\', offset: -5, fontSize: 10 }} tick={{ fontSize: 10 }} />\n                <YAxis domain={[60, 210]} label={{ value: \'Max HR\', angle: -90, position: \'insideLeft\', fontSize: 10 }} tick={{ fontSize: 10 }} />\n                <Tooltip \n                  content={({ active, payload }) => {\n                    if (active && payload && payload.length) {\n                      const data = payload[0].payload;\n                      return (\n                        <div className=\"bg-white p-3 border border-slate-100 rounded-lg shadow-md text-xs space-y-1\">\n                          <p className=\"font-bold text-slate-800\">{data.name}</p>\n                          <p className=\"text-slate-600\">Age: <span className=\"font-semibold\">{data.age} yrs</span></p>\n                          <p className=\"text-slate-600\">Peak Heart Rate: <span className=\"font-semibold text-rose-600\">{data.maxHR} bpm</span></p>\n                          <p className=\"text-indigo-650 font-bold mt-1\">Calculated risk probability: {data.probability}%</p>\n                        </div>\n                      );\n                    }\n                    return null;\n                  }}\n                />\n                <Area type=\"monotone\" dataKey=\"maxHR\" stroke=\"#ec4899\" strokeWidth={2} fillOpacity={1} fill=\"url(#colorMaxHR)\" name=\"Cardiomax BPM\" />\n              </AreaChart>\n            </ResponsiveContainer>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Analytical Medical Insight Section */}\n      <div id=\"clinical-academic-insights\" className=\"bg-slate-50 rounded-2xl p-5 border border-slate-100\">\n        <h4 className=\"text-sm font-bold text-slate-800 flex items-center gap-1.5 mb-2\">\n          <Users className=\"w-5 h-5 text-indigo-500\" />\n          General Cardiologic Profile Summary\n        </h4>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 text-xs text-slate-600 leading-relaxed\">\n          <div className=\"space-y-2\">\n            <p>\n              This heart disease statistics registry focuses heavily on angiographic and non-invasive stress data. Over <strong>{ summary.genderDistribution.diseaseM + summary.genderDistribution.diseaseF } patients</strong> demonstrate heightened risk scores. \n            </p>\n            <p>\n              In the original Kaggle dataset, the <strong>ST Segment Slope</strong> type <span className=\"text-amber-600 font-semibold\">Flat</span> and <span className=\"text-red-650 font-semibold\">Downsloping</span> are the single highest correlated variables indicating current left-ventricular artery compromise or microvascular failure.\n            </p>\n          </div>\n          <div className=\"space-y-2\">\n            <p>\n              Another crucial clinical marker present in this pool is <strong>Chronotropic Incompetence</strong>, visually represented by maximum cardiac frequency below expected sub-maximal thresholds ({records.some(r => r.maxHR < 120) ? \'Noticeable low heart rates are registered here\' : \'Check stress-test outputs for verification\'}).\n            </p>\n            <div className=\"p-3 bg-white border border-slate-100 rounded-xl flex items-center justify-between\">\n              <div>\n                <span className=\"font-bold text-slate-700 block\">Ischemia Angina Prevalence</span>\n                <span className=\"text-[11px] text-slate-450 block mt-0.5\">Physical exertion inducing acute angina signals.</span>\n              </div>\n              <span className=\"text-lg font-black text-rose-600\">\n                {records.filter(r => r.exerciseAngina === \'Y\').length} Cases\n              </span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
