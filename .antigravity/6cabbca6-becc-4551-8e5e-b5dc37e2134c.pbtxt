          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        recommendations: aiReport?.recommendations,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
