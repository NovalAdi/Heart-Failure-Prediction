      target_content: "  const saveToSystem = () => {\n    if (!localPrediction) return;\n    const finalRecord: PatientRecord = {\n      ...formData,\n      id: \'patient-\' + Date.now(),\n      name: formData.name.trim() || `Patient #${Math.floor(Math.random() * 9000) + 1000}`,\n      prediction: {\n        ...localPrediction,\n        clinicalInterpretation: aiReport?.clinicalInterpretation,\n        recommendations: aiReport?.recommendations,\n      }\n    };\n    onAddRecord(finalRecord);\n    \n    // Reset or notify\n    alert(\'Patient record with diagnostic report saved successfully!\');\n    // Keep form as is but reset state\n    setLocalPrediction(null);\n    setAiReport(null);\n    setFormData({\n      name: \'\',\n      age: 55,\n      sex: \'M\',\n      chestPainType: \'ASY\',\n      restingBP: 130,\n      cholesterol: 220,\n      fastingBS: 0,\n      restingECG: \'Normal\',\n      maxHR: 140,\n      exerciseAngina: \'N\',\n      oldpeak: 1.0,\n      stSlope: \'Flat\',\n    });\n  };\n\n  return (\n    <div id=\"manual-form-container\" className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n      {/* Input Form Column */}\n      <form onSubmit={executeLocalAnalysis} id=\"cardiac-input-form\" className=\"lg:col-span-7 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm space-y-6\">\n        <div className=\"border-b border-slate-100 pb-4\">\n          <h2 className=\"text-xl font-bold text-slate-800 flex items-center gap-2\">\n            <Activity className=\"w-5 h-5 text-red-500\" />\n            Cardiovascular Parameter Checklist\n          </h2>\n          <p className=\"text-sm text-slate-500 mt-1\">\n            Input the patient\'s quantitative measurements and angiographic responses modeled directly from the Kaggle heart failure dataset.\n          </p>\n        </div>\n\n        {/* Section: Basic Demographics */}\n        <div className=\"space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Section 1: General Profile</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-name\">Patient Name / Identifier</label>\n              <input\n                id=\"patient-name\"\n                type=\"text\"\n                name=\"name\"\n                value={formData.name}\n                onChange={handleInputChange}\n                placeholder=\"Optional (e.g. John Doe)\"\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-2\">\n              <div>\n                <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-age\">Age (Years) <span className=\"text-red-500\">*</span></label>\n                <input\n                  id=\"patient-age\"\n                  type=\"number\"\n                  name=\"age\"\n                  min=\"20\"\n                  max=\"120\"\n                  required\n                  value={formData.age}\n                  onChange={handleInputChange}\n                  className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-sex\">Biological Sex <span className=\"text-red-500\">*</span></label>\n                <select\n                  id=\"patient-sex\"\n                  name=\"sex\"\n                  value={formData.sex}\n                  onChange={handleInputChange}\n                  className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n                >\n                  <option value=\"M\">Male (M)</option>\n                  <option value=\"F\">Female (F)</option>\n                </select>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Angina Indications */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Section 2: Angiographic & Pain Indications</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-chestpain\">Chest Pain Type (CP) <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-chestpain\"\n                name=\"chestPainType\"\n                value={formData.chestPainType}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"ASY\">ASY: Asymptomatic (High Risk indicator!)</option>\n                <option value=\"TA\">TA: Typical Angina</option>\n                <option value=\"ATA\">ATA: Atypical Angina</option>\n                <option value=\"NAP\">NAP: Non-Anginal Pain</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                * Note: Statistically in the clinical dataset, asymptomatic patients with risk factors face high silent cardiovascular compromises.\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-exang\">Exercise Angina <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-exang\"\n                name=\"exerciseAngina\"\n                value={formData.exerciseAngina}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"N\">No (Absent)</option>\n                <option value=\"Y\">Yes (Induced by Exertion)</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                Signals typical lack of healthy coronary arterial compensatory expansion.\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Physiological Vitals */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Section 3: Vitals & Blood Profile</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-bp\">Resting BP (mmHg) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-bp\"\n                type=\"number\"\n                name=\"restingBP\"\n                min=\"0\"\n                max=\"240\"\n                required\n                value={formData.restingBP}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Normal: ~120 mmHg</span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-chol\">Serum Chol. (mg/dl) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-chol\"\n                type=\"number\"\n                name=\"cholesterol\"\n                min=\"0\"\n                max=\"600\"\n                required\n                value={formData.cholesterol}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Normal: &lt;200 mg/dl (0: Unrecorded)</span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-fbs\">Fasting Blood Sugar <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-fbs\"\n                name=\"fastingBS\"\n                value={formData.fastingBS}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value={0}>Normal (\342\211\244120 mg/dl)</option>\n                <option value={1}>Elevated (&gt;120 mg/dl)</option>\n              </select>\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Indicative of glycemic stress</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Electrocardiogram metrics */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Section 4: Stress-Test Electrocardiogram</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-ecg\">Resting ECG Results <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-ecg\"\n                name=\"restingECG\"\n                value={formData.restingECG}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"Normal\">Normal baseline</option>\n                <option value=\"ST\">ST: ST-T wave abnormalities</option>\n                <option value=\"LVH\">LVH: Left Ventricular Hypertrophy</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                Identifies ventricular strain or acute ischemic stress signatures.\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-maxhr\">Max Heart Rate (bpm) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-maxhr\"\n                type=\"number\"\n                name=\"maxHR\"\n                min=\"60\"\n                max=\"220\"\n                required\n                value={formData.maxHR}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight font-mono text-right\">\n                Expected target: {220 - formData.age} bpm max\n              </span>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 pt-2\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-oldpeak\">ST Depression (Oldpeak) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-oldpeak\"\n                type=\"number\"\n                name=\"oldpeak\"\n                min=\"0.0\"\n                max=\"10.0\"\n                step=\"0.1\"\n                required\n                value={formData.oldpeak}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                ST peak distance difference relative to resting state in mm.\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-slope\">Peak Exercise ST Slope <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-slope\"\n                name=\"stSlope\"\n                value={formData.stSlope}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"Up\">Up: Upsloping (Lowest risk profile)</option>\n                <option value=\"Flat\">Flat: Flat line (Elevated risk)</option>\n                <option value=\"Down\">Down: Downsloping (High Risk ischemia)</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight font-medium text-amber-600\">\n                ST slopes represent critical diagnostic triggers in patients.\n              </span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"pt-4 flex gap-3\">\n          <button\n            type=\"submit\"\n            id=\"btn-local-analyse\"\n            className=\"flex-1 bg-slate-900 text-white font-semibold py-2.5 px-4 rounded-xl hover:bg-slate-800 transition active:scale-98 text-sm flex items-center justify-center gap-2 cursor-pointer\"\n          >\n            <Sliders className=\"w-4 h-4\" />\n            Analyze Locally\n          </button>\n        </div>\n      </form>\n\n      {/* Results View Column */}\n      <div id=\"results-display-column\" className=\"lg:col-span-12 xl:col-span-5 space-y-6\">\n        {!localPrediction ? (\n          <div className=\"bg-slate-50 border border-slate-100 rounded-2xl p-8 text-center text-slate-500 flex flex-col items-center justify-center space-y-4\">\n            <div className=\"p-3 bg-white rounded-full shadow-sm text-slate-300\">\n              <Heart className=\"w-8 h-8 animate-pulse text-slate-400\" />\n            </div>\n            <div>\n              <h3 className=\"font-semibold text-slate-700 text-base\">Awaiting Diagnostic Input</h3>\n              <p className=\"text-sm mt-1 max-w-sm\">\n                Fill the cardiovascular parameters and click \"Analyze Locally\" to run the algorithm based on official Kaggle trends.\n              </p>\n            </div>\n          </div>\n        ) : (\n          <div className=\"space-y-6\">\n            {/* Probability summary card */}\n            <div className=\"bg-white border border-slate-100 rounded-2xl shadow-sm p-6 overflow-hidden relative\">\n              <div className=\"absolute top-0 left-0 w-2 h-full bg-red-500\"></div>\n              \n              <div className=\"flex items-center justify-between mb-4\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Diagnostic Summary</span>\n                <span className={`px-2.5 py-1 rounded-full text-xs font-bold leading-none ${\n                  localPrediction.riskLevel === \'Critical\' ? \'bg-red-50 text-red-700 border border-red-100\' :\n                  localPrediction.riskLevel === \'High\' ? \'bg-amber-50 text-amber-700 border border-amber-100\' :\n                  localPrediction.riskLevel === \'Moderate\' ? \'bg-yellow-50 text-yellow-700 border border-yellow-105\' :\n                  \'bg-emerald-50 text-emerald-700 border border-emerald-100\'\n                }`}>\n                  {localPrediction.riskLevel} Risk\n                </span>\n              </div>\n\n              <div className=\"flex items-baseline gap-2\">\n                <span className=\"text-4xl font-extrabold text-slate-800\">{localPrediction.heartDiseaseProbability}%</span>\n                <span className=\"text-sm font-medium text-slate-500\">Heart Failure Likelihood</span>\n              </div>\n\n              {/* Progress bar */}\n              <div className=\"w-full bg-slate-100 h-2.5 rounded-full mt-3 overflow-hidden\">\n                <div\n                  className={`h-full rounded-full transition-all duration-500 ${\n                    localPrediction.riskLevel === \'Critical\' ? \'bg-red-600\' :\n                    localPrediction.riskLevel === \'High\' ? \'bg-red-500\' :\n                    localPrediction.riskLevel === \'Moderate\' ? \'bg-amber-500\' :\n                    \'bg-emerald-500\'\n                  }`}\n                  style={{ width: `${localPrediction.heartDiseaseProbability}%` }}\n                ></div>\n              </div>\n\n              <div className=\"grid grid-cols-3 gap-2 mt-4 pt-4 border-t border-slate-100 text-center text-xs\">\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5\">ECG</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.restingECG}</span>\n                </div>\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5\">BP</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.restingBP}</span>\n                </div>\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5\">Slope</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.stSlope}</span>\n                </div>\n              </div>\n            </div>\n\n            {/* AI Integration consulting trigger */}\n            <div className=\"bg-gradient-to-br from-indigo-50 to-purple-50 hover:from-indigo-50/70 border border-indigo-200/50 p-5 rounded-2xl shadow-xs space-y-4\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"p-2 bg-indigo-500 rounded-xl text-white\">\n                  <Sparkles className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-slate-800 text-sm\">Enhance with Gemini Diagnostic Pro</h4>\n                  <p className=\"text-xs text-slate-600 mt-0.5\">\n                    Connect securely to Gemini to translate these raw metrics into a professional cardiology interpretation and lifestyle directives.\n                  </p>\n                </div>\n              </div>\n\n              {aiError && (\n                <div className=\"p-3 bg-red-50 border border-red-100 rounded-xl text-xs text-red-600 flex items-start gap-2 leading-relaxed\">\n                  <AlertTriangle className=\"w-4 h-4 shrink-0 mt-0.5 text-red-500\" />\n                  <div>\n                    <span className=\"font-semibold\">Consultation unavailable:</span> {aiError}\n                  </div>\n                </div>\n              )}\n\n              {aiReport ? (\n                <div className=\"space-y-4 pt-2 border-t border-indigo-100\">\n                  <div className=\"space-y-1 bg-white p-4 rounded-xl border border-indigo-50 text-xs text-slate-700 leading-relaxed max-h-[250px] overflow-y-auto\">\n                    <span className=\"font-bold text-indigo-900 block mb-1 flex items-center gap-1\">\n                      <ShieldAlert className=\"w-3.5 h-3.5 text-red-500\" />\n                      Clinical Interpretation\n                    </span>\n                    <p className=\"whitespace-pre-line\">{aiReport.clinicalInterpretation}</p>\n                  </div>\n\n                  <div className=\"space-y-1\">\n                    <span className=\"font-bold text-indigo-900 text-xs block mb-1\">Personalized Directives & Checkups</span>\n                    <ul className=\"space-y-1\">\n                      {aiReport.recommendations.map((rec, idx) => (\n                        <li key={idx} className=\"bg-white border border-indigo-50 px-3 py-2 rounded-lg text-xs text-slate-700 flex items-start gap-2 shadow-2xs\">\n                          <span className=\"flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-[10px] font-bold text-indigo-800\">\n                            {idx + 1}\n                          </span>\n                          <span>{rec}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n                </div>\n              ) : (\n                <button\n                  type=\"button\"\n                  id=\"btn-gems-report\"\n                  disabled={isAiLoading}\n                  onClick={getAiConsultation}\n                  className=\"w-full bg-indigo-600 hover:bg-indigo-700 transition active:scale-98 text-white font-semibold text-xs py-2 px-4 rounded-xl flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50\"\n                >\n                  {isAiLoading ? (\n                    <>\n                      <Loader2 className=\"w-4 h-4 animate-spin\" />\n                      Querying Advanced Cardiologist Model...\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-4 h-4\" />\n                      Request AI Clinical Report\n                    </>\n                  )}\n                </button>\n              )}\n            </div>\n\n            {/* List key risk warning factors */}\n            <div className=\"bg-white border border-slate-100 rounded-2xl shadow-sm p-5 space-y-3\">\n              <h4 className=\"text-xs font-bold uppercase tracking-wider text-slate-400\">Primary Local Diagnostic Findings</h4>\n              {localPrediction.riskFactors.length === 0 ? (\n                <p className=\"text-xs text-slate-500 italic\">No significant risk triggers detected under local screening.</p>\n              ) : (\n                <div className=\"space-y-2\">\n                  {localPrediction.riskFactors.map((rf, idx) => (\n                    <div key={idx} className=\"flex gap-2.5 p-2 rounded-lg bg-orange-50/50 border border-orange-100/50\">\n                      <AlertTriangle className=\"w-4 h-4 text-orange-600 shrink-0 mt-0.5\" />\n                      <div>\n                        <span className=\"text-xs font-bold text-slate-800 block\">\n                          {rf.factor}\n                          <span className=\"ml-1.5 px-1 py-0.2 text-[9px] uppercase font-extrabold bg-orange-100 text-orange-850 rounded\">\n                            {rf.impact} Impact\n                          </span>\n                        </span>\n                        <p className=\"text-xs text-slate-650 leading-relaxed mt-0.5\">{rf.description}</p>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n\n            {/* Action panel to save results */}\n            <div className=\"bg-slate-50 p-4 rounded-xl border border-slate-100 flex items-center justify-between\">\n              <div>\n                <span className=\"text-slate-800 text-xs font-bold block\">Save Diagnostic Entry?</span>\n                <span className=\"text-slate-500 text-[11px] block mt-0.5\">Appends this analysis and its charts/reports to local database history.</span>\n              </div>\n              <button\n                type=\"button\"\n                id=\"btn-save-record\"\n                onClick={saveToSystem}\n                className=\"bg-emerald-600 hover:bg-emerald-700 transition text-white px-3.5 py-1.5 rounded-lg text-xs font-bold cursor-pointer\"\n              >\n                Log Into History\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}"
      replacement_content: "  const saveToSystem = () => {\n    if (!localPrediction) return;\n    const finalRecord: PatientRecord = {\n      ...formData,\n      id: \'patient-\' + Date.now(),\n      name: formData.name.trim() || `Pasien #${Math.floor(Math.random() * 9000) + 1000}`,\n      prediction: {\n        ...localPrediction,\n        clinicalInterpretation: aiReport?.clinicalInterpretation,\n        recommendations: aiReport?.recommendations,\n      }\n    };\n    onAddRecord(finalRecord);\n    \n    // Reset or notify\n    alert(\'Catatan rekam medis pasien dengan laporan diagnostik berhasil disimpan!\');\n    // Keep form as is but reset state\n    setLocalPrediction(null);\n    setAiReport(null);\n    setFormData({\n      name: \'\',\n      age: 55,\n      sex: \'M\',\n      chestPainType: \'ASY\',\n      restingBP: 130,\n      cholesterol: 220,\n      fastingBS: 0,\n      restingECG: \'Normal\',\n      maxHR: 140,\n      exerciseAngina: \'N\',\n      oldpeak: 1.0,\n      stSlope: \'Flat\',\n    });\n  };\n\n  return (\n    <div id=\"manual-form-container\" className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n      {/* Input Form Column */}\n      <form onSubmit={executeLocalAnalysis} id=\"cardiac-input-form\" className=\"lg:col-span-7 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm space-y-6\">\n        <div className=\"border-b border-slate-100 pb-4\">\n          <h2 className=\"text-xl font-bold text-slate-800 flex items-center gap-2\">\n            <Activity className=\"w-5 h-5 text-red-500\" />\n            Daftar Parameter Kardiovaskular Pasien\n          </h2>\n          <p className=\"text-sm text-slate-500 mt-1\">\n            Masukkan pengukuran kuantitatif dan respons angiografis pasien yang dimodelkan langsung dari dataset gagal jantung Kaggle.\n          </p>\n        </div>\n\n        {/* Section: Basic Demographics */}\n        <div className=\"space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Bagian 1: Profil Umum</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-name\">Nama Pasien / Pengenal</label>\n              <input\n                id=\"patient-name\"\n                type=\"text\"\n                name=\"name\"\n                value={formData.name}\n                onChange={handleInputChange}\n                placeholder=\"Opsional (mis. Ahmad Fadli)\"\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-2\">\n              <div>\n                <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-age\">Usia (Tahun) <span className=\"text-red-500\">*</span></label>\n                <input\n                  id=\"patient-age\"\n                  type=\"number\"\n                  name=\"age\"\n                  min=\"20\"\n                  max=\"120\"\n                  required\n                  value={formData.age}\n                  onChange={handleInputChange}\n                  className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-sex\">Jenis Kelamin <span className=\"text-red-500\">*</span></label>\n                <select\n                  id=\"patient-sex\"\n                  name=\"sex\"\n                  value={formData.sex}\n                  onChange={handleInputChange}\n                  className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n                >\n                  <option value=\"M\">Laki-laki (M)</option>\n                  <option value=\"F\">Perempuan (F)</option>\n                </select>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Angina Indications */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Bagian 2: Indikasi Angina & Nyeri Dada</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-chestpain\">Tipe Nyeri Dada (CP) <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-chestpain\"\n                name=\"chestPainType\"\n                value={formData.chestPainType}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"ASY\">ASY: Asimtomatik (Indikator Risiko Tinggi!)</option>\n                <option value=\"TA\">TA: Angina Tipikal (Typical Angina)</option>\n                <option value=\"ATA\">ATA: Angina Atipikal (Atypical Angina)</option>\n                <option value=\"NAP\">NAP: Nyeri Non-Anginal (Non-Anginal Pain)</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                * Catatan: Secara statistik dalam dataset klinis, pasien asimtomatik dengan faktor risiko kardiak menghadapi kompromi kardiovaskular senyap yang tinggi.\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-exang\">Angina Latihan <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-exang\"\n                name=\"exerciseAngina\"\n                value={formData.exerciseAngina}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"N\">Tidak Ada (N)</option>\n                <option value=\"Y\">Ya, Dipicu Aktivitas Fisik (Y)</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                Menandakan ketidakmampuan arteri koroner beradaptasi sehat terhadap beban latihan fisik.\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Physiological Vitals */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Bagian 3: Tanda Vital & Profil Darah</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-bp\">TD Istirahat (mmHg) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-bp\"\n                type=\"number\"\n                name=\"restingBP\"\n                min=\"0\"\n                max=\"240\"\n                required\n                value={formData.restingBP}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Normal: ~120 mmHg</span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-chol\">Kolesterol Serum (mg/dl) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-chol\"\n                type=\"number\"\n                name=\"cholesterol\"\n                min=\"0\"\n                max=\"600\"\n                required\n                value={formData.cholesterol}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Normal: &lt;200 mg/dl (0: Tidak Tercantum)</span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-fbs\">Gula Darah Puasa <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-fbs\"\n                name=\"fastingBS\"\n                value={formData.fastingBS}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value={0}>Normal (\342\211\244120 mg/dl)</option>\n                <option value={1}>Tinggi / Diabetes (&gt;120 mg/dl)</option>\n              </select>\n              <span className=\"text-[10px] text-slate-400 mt-1 block\">Indikasi tingkat stres glikemik</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Section: Electrocardiogram metrics */}\n        <div className=\"pt-2 space-y-4\">\n          <h3 className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Bagian 4: Elektrocardiogram Uji Stres</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-ecg\">Hasil EKG Istirahat <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-ecg\"\n                name=\"restingECG\"\n                value={formData.restingECG}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"Normal\">Normal baseline</option>\n                <option value=\"ST\">ST: Abnormalitas gelombang ST-T</option>\n                <option value=\"LVH\">LVH: Hipertrofi Ventrikel Kiri</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                Mengidentifikasi tanda regangan ventrikel atau iskemia miokard akut.\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-maxhr\">Detak Jantung Maksimal (bpm) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-maxhr\"\n                type=\"number\"\n                name=\"maxHR\"\n                min=\"60\"\n                max=\"220\"\n                required\n                value={formData.maxHR}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight font-mono text-right\">\n                Target sub-maksimal teori: {220 - formData.age} bpm maks\n              </span>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 pt-2\">\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-oldpeak\">Depresi ST (Oldpeak) <span className=\"text-red-500\">*</span></label>\n              <input\n                id=\"patient-oldpeak\"\n                type=\"number\"\n                name=\"oldpeak\"\n                min=\"0.0\"\n                max=\"10.0\"\n                step=\"0.1\"\n                required\n                value={formData.oldpeak}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              />\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight\">\n                Selisih depresi puncak ST dibanding keadaan istirahat (dalam mm).\n              </span>\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-medium text-slate-700 mb-1\" htmlFor=\"patient-slope\">Kemiringan ST Latihan Puncak <span className=\"text-red-500\">*</span></label>\n              <select\n                id=\"patient-slope\"\n                name=\"stSlope\"\n                value={formData.stSlope}\n                onChange={handleInputChange}\n                className=\"w-full px-3 py-2 border border-slate-200 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500 text-sm\"\n              >\n                <option value=\"Up\">Up: Menanjak / Upsloping (Risiko Paling Rendah)</option>\n                <option value=\"Flat\">Flat: Garis Datar / Flat (Risiko Tinggi)</option>\n                <option value=\"Down\">Down: Menurun / Downsloping (Risiko Iskemia Akut)</option>\n              </select>\n              <span className=\"text-[11px] text-slate-400 mt-1 block leading-tight font-medium text-amber-600\">\n                Pola kemiringan ST adalah faktor pemicu penilaian klinis utama kardiologi.\n              </span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"pt-4 flex gap-3\">\n          <button\n            type=\"submit\"\n            id=\"btn-local-analyse\"\n            className=\"flex-1 bg-slate-900 text-white font-semibold py-2.5 px-4 rounded-xl hover:bg-slate-800 transition active:scale-98 text-sm flex items-center justify-center gap-2 cursor-pointer\"\n          >\n            <Sliders className=\"w-4 h-4\" />\n            Analisis Secara Lokal\n          </button>\n        </div>\n      </form>\n\n      {/* Results View Column */}\n      <div id=\"results-display-column\" className=\"lg:col-span-12 xl:col-span-5 space-y-6\">\n        {!localPrediction ? (\n          <div className=\"bg-slate-50 border border-slate-100 rounded-2xl p-8 text-center text-slate-500 flex flex-col items-center justify-center space-y-4\">\n            <div className=\"p-3 bg-white rounded-full shadow-sm text-slate-300\">\n              <Heart className=\"w-8 h-8 animate-pulse text-slate-400\" />\n            </div>\n            <div>\n              <h3 className=\"font-semibold text-slate-700 text-base\">Menunggu Input Diagnostik</h3>\n              <p className=\"text-sm mt-1 max-w-sm\">\n                Isi parameter kardiovaskular pasien di sebelah kiri dan klik \"Analisis Secara Lokal\" untuk memproses algoritma klinis.\n              </p>\n            </div>\n          </div>\n        ) : (\n          <div className=\"space-y-6\">\n            {/* Probability summary card */}\n            <div className=\"bg-white border border-slate-100 rounded-2xl shadow-sm p-6 overflow-hidden relative\">\n              <div className=\"absolute top-0 left-0 w-2 h-full bg-red-500\"></div>\n              \n              <div className=\"flex items-center justify-between mb-4\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider text-slate-400\">Ringkasan Diagnostik</span>\n                <span className={`px-2.5 py-1 rounded-full text-xs font-bold leading-none ${\n                  localPrediction.riskLevel === \'Critical\' ? \'bg-red-50 text-red-700 border border-red-100\' :\n                  localPrediction.riskLevel === \'High\' ? \'bg-amber-50 text-amber-700 border border-amber-100\' :\n                  localPrediction.riskLevel === \'Moderate\' ? \'bg-yellow-50 text-yellow-700 border border-yellow-100\' :\n                  \'bg-emerald-50 text-emerald-700 border border-emerald-100\'\n                }`}>\n                  Risiko {localPrediction.riskLevel === \'Critical\' ? \'Kritis (Critical)\' :\n                          localPrediction.riskLevel === \'High\' ? \'Tinggi (High)\' :\n                          localPrediction.riskLevel === \'Moderate\' ? \'Sedang (Moderate)\' :\n                          \'Rendah (Low)\'}\n                </span>\n              </div>\n\n              <div className=\"flex items-baseline gap-2\">\n                <span className=\"text-4xl font-extrabold text-slate-800\">{localPrediction.heartDiseaseProbability}%</span>\n                <span className=\"text-sm font-medium text-slate-500\">Probabilitas Gagal Jantung</span>\n              </div>\n\n              {/* Progress bar */}\n              <div className=\"w-full bg-slate-100 h-2.5 rounded-full mt-3 overflow-hidden\">\n                <div\n                  className={`h-full rounded-full transition-all duration-500 ${\n                    localPrediction.riskLevel === \'Critical\' ? \'bg-red-600\' :\n                    localPrediction.riskLevel === \'High\' ? \'bg-red-500\' :\n                    localPrediction.riskLevel === \'Moderate\' ? \'bg-amber-500\' :\n                    \'bg-emerald-500\'\n                  }`}\n                  style={{ width: `${localPrediction.heartDiseaseProbability}%` }}\n                ></div>\n              </div>\n\n              <div className=\"grid grid-cols-3 gap-2 mt-4 pt-4 border-t border-slate-100 text-center text-xs\">\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5\">EKG</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.restingECG}</span>\n                </div>\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5\">TD</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.restingBP}</span>\n                </div>\n                <div className=\"bg-slate-50 p-2 rounded-lg\">\n                  <span className=\"text-slate-400 block mb-0.5 font-mono\">ST Slope</span>\n                  <span className=\"font-semibold text-slate-700 block\">{formData.stSlope}</span>\n                </div>\n              </div>\n            </div>\n\n            {/* AI Integration consulting trigger */}\n            <div className=\"bg-gradient-to-br from-indigo-50 to-purple-50 hover:from-indigo-50/70 border border-indigo-200/50 p-5 rounded-2xl shadow-xs space-y-4\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"p-2 bg-indigo-500 rounded-xl text-white\">\n                  <Sparkles className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-slate-800 text-sm\">Tingkatkan dengan Gemini Diagnostic Pro</h4>\n                  <p className=\"text-xs text-slate-600 mt-0.5\">\n                    Hubungkan data klinis ini ke Gemini AI untuk menerjemahkan nilai telemetri mentah menjadi interpretasi kardiologi profesional serta rekomendasi gaya hidup medis.\n                  </p>\n                </div>\n              </div>\n\n              {aiError && (\n                <div className=\"p-3 bg-red-50 border border-red-100 rounded-xl text-xs text-red-600 flex items-start gap-2 leading-relaxed\">\n                  <AlertTriangle className=\"w-4 h-4 shrink-0 mt-0.5 text-red-500\" />\n                  <div>\n                    <span className=\"font-semibold\">Konsultasi AI tidak tersedia:</span> {aiError}\n                  </div>\n                </div>\n              )}\n\n              {aiReport ? (\n                <div className=\"space-y-4 pt-2 border-t border-indigo-100\">\n                  <div className=\"space-y-1 bg-white p-4 rounded-xl border border-indigo-50 text-xs text-slate-700 leading-relaxed max-h-[250px] overflow-y-auto\">\n                    <span className=\"font-bold text-indigo-900 block mb-1 flex items-center gap-1\">\n                      <ShieldAlert className=\"w-3.5 h-3.5 text-red-500\" />\n                      Interpretasi Klinis Ahli Jantung\n                    </span>\n                    <p className=\"whitespace-pre-line\">{aiReport.clinicalInterpretation}</p>\n                  </div>\n\n                  <div className=\"space-y-1\">\n                    <span className=\"font-bold text-indigo-900 text-xs block mb-1\">Rekomendasi Skrining & Gaya Hidup</span>\n                    <ul className=\"space-y-1\">\n                      {aiReport.recommendations.map((rec, idx) => (\n                        <li key={idx} className=\"bg-white border border-indigo-50 px-3 py-2 rounded-lg text-xs text-slate-700 flex items-start gap-2 shadow-2xs\">\n                          <span className=\"flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-[10px] font-bold text-indigo-800\">\n                            {idx + 1}\n                          </span>\n                          <span>{rec}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n                </div>\n              ) : (\n                <button\n                  type=\"button\"\n                  id=\"btn-gems-report\"\n                  disabled={isAiLoading}\n                  onClick={getAiConsultation}\n                  className=\"w-full bg-indigo-600 hover:bg-indigo-700 transition active:scale-98 text-white font-semibold text-xs py-2 px-4 rounded-xl flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50\"\n                >\n                  {isAiLoading ? (\n                    <>\n                      <Loader2 className=\"w-4 h-4 animate-spin\" />\n                      Menghubungi Ahli Jantung Digital (Gemini AI)...\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-4 h-4\" />\n                      Dapatkan Laporan Klinis Gemini AI\n                    </>\n                  )}\n                </button>\n              )}\n            </div>\n\n            {/* List key risk warning factors */}\n            <div className=\"bg-white border border-slate-100 rounded-2xl shadow-sm p-5 space-y-3\">\n              <h4 className=\"text-xs font-bold uppercase tracking-wider text-slate-400\">Temuan Faktor Risiko Utama Lokal</h4>\n              {localPrediction.riskFactors.length === 0 ? (\n                <p className=\"text-xs text-slate-500 italic\">Tidak ada pemicu risiko signifikan yang terdeteksi dalam penyaringan lokal luar.</p>\n              ) : (\n                <div className=\"space-y-2\">\n                  {localPrediction.riskFactors.map((rf, idx) => (\n                    <div key={idx} className=\"flex gap-2.5 p-2 rounded-lg bg-orange-50/50 border border-orange-100/50\">\n                      <AlertTriangle className=\"w-4 h-4 text-orange-600 shrink-0 mt-0.5\" />\n                      <div>\n                        <span className=\"text-xs font-bold text-slate-800 block\">\n                          {rf.factor}\n                          <span className=\"ml-1.5 px-2 py-0.2 text-[9px] uppercase font-extrabold bg-orange-100 text-orange-850 rounded\">\n                            Dampak {rf.impact === \'High\' ? \'Tinggi\' : rf.impact === \'Medium\' ? \'Sedang\' : \'Rendah\'}\n                          </span>\n                        </span>\n                        <p className=\"text-xs text-slate-650 leading-relaxed mt-0.5\">{rf.description}</p>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n\n            {/* Action panel to save results */}\n            <div className=\"bg-slate-50 p-4 rounded-xl border border-slate-100 flex items-center justify-between\">\n              <div>\n                <span className=\"text-slate-800 text-xs font-bold block\">Simpan Rekam Medis Ini?</span>\n                <span className=\"text-slate-500 text-[11px] block mt-0.5\">Memasukkan analisis kardiologi ini ke dalam riwayat repositori kualitatif lokal.</span>\n              </div>\n              <button\n                type=\"button\"\n                id=\"btn-save-record\"\n                onClick={saveToSystem}\n                className=\"bg-emerald-600 hover:bg-emerald-700 transition text-white px-3.5 py-1.5 rounded-lg text-xs font-bold cursor-pointer\"\n              >\n                Simpan ke Riwayat\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}"
    }
