        lines {
          text: "        body: JSON.stringify({"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          patient: formData,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          prediction: localPrediction"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        })"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (!response.ok) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const errorData = await response.json();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        throw new Error(errorData.error || \'Server diagnostic endpoint returned an error.\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const data = await response.json();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setAiReport(data);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } catch (err: any) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      console.error(err);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setAiError(err.message || \'Failed to connect to the Gemini server endpoint.\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } finally {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setIsAiLoading(false);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
