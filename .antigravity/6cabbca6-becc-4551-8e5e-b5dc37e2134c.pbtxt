  file_change {
    absolute_path_uri: "file:///src/components/ManualForm.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { PatientRecord } from \'../types\';\nimport { Heart, RefreshCw, UserPlus } from \'lucide-react\';\n\ninterface ManualFormProps {\n  onAnalyze: (patient: Omit<PatientRecord, \'id\' | \'prediction\'> & { name: string }) => void;\n}\n\nexport default function ManualForm({ onAnalyze }: ManualFormProps) {\n  const [formData, setFormData] = useState({\n    name: \'\',\n    age: 55,\n    sex: \'M\' as \'M\' | \'F\',\n    chestPainType: \'ASY\' as \'TA\' | \'ATA\' | \'NAP\' | \'ASY\',\n    restingBP: 125,\n    cholesterol: 210,\n    fastingBS: 0 as 0 | 1,\n    restingECG: \'Normal\' as \'Normal\' | \'ST\' | \'LVH\',\n    maxHR: 140,\n    exerciseAngina: \'N\' as \'Y\' | \'N\',\n    oldpeak: 1.0,\n    stSlope: \'Flat\' as \'Up\' | \'Flat\' | \'Down\',\n  });\n\n  const generateRandomDemo = () => {\n    const maleNames = [\'David Carter\', \'Marcus Vance\', \'Arthur Pendelton\', \'Liam O\\\'Connor\', \'Kenji Sato\'];\n    const femaleNames = [\'Elena Rostova\', \'Beatrice Thorne\', \'Amira Al-Fayed\', \'Clara Schumann\', \'Isabella Gomez\'];\n    const livesInRisk = Math.random() > 0.4;\n    const isMale = Math.random() > 0.3;\n    const name = isMale \n      ? maleNames[Math.floor(Math.random() * maleNames.length)]\n      : femaleNames[Math.floor(Math.random() * femaleNames.length)];\n\n    if (livesInRisk) {\n      setFormData({\n        name,\n        age: Math.floor(Math.random() * 25) + 50, // 50 to 75\n        sex: isMale ? \'M\' : \'F\',\n        chestPainType: Math.random() > 0.3 ? \'ASY\' : \'TA\',\n        restingBP: Math.floor(Math.random() * 50) + 130, // 130 to 180\n        cholesterol: Math.random() > 0.2 ? Math.floor(Math.random() * 120) + 210 : 0, // high or unrecorded\n        fastingBS: Math.random() > 0.5 ? 1 : 0,\n        restingECG: Math.random() > 0.5 ? \'LVH\' : \'ST\',\n        maxHR: Math.floor(Math.random() * 40) + 90, // 90 to 130\n        exerciseAngina: \'Y\',\n        oldpeak: Math.round((Math.random() * 3.5 + 0.8) * 10) / 10, // 0.8 to 4.3\n        stSlope: Math.random() > 0.3 ? \'Flat\' : \'Down\',\n      });\n    } else {\n      setFormData({\n        name,\n        age: Math.floor(Math.random() * 20) + 25, // 25 to 45\n        sex: isMale ? \'M\' : \'F\',\n        chestPainType: Math.random() > 0.5 ? \'ATA\' : \'NAP\',\n        restingBP: Math.floor(Math.random() * 20) + 110, // 110 to 130\n        cholesterol: Math.floor(Math.random() * 60) + 160, // 160 to 220\n        fastingBS: 0,\n        restingECG: \'Normal\',\n        maxHR: Math.floor(Math.random() * 40) + 150, // 150 to 190\n        exerciseAngina: \'N\',\n        oldpeak: 0.0,\n        stSlope: \'Up\',\n      });\n    }\n  };\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    onAnalyze({\n      ...formData,\n      name: formData.name.trim() || `Patient #${Math.floor(Math.random() * 900) + 100}`,\n    });\n  };\n\n  return (\n    <div id=\"manual_form_container\" className=\"bg-white rounded-2xl border border-slate-100 p-6 shadow-xs\">\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 pb-4 border-b border-slate-100\">\n        <div>\n          <h2 id=\"manual_form_title\" className=\"text-lg font-semibold text-slate-900 flex items-center gap-2\">\n            <Heart className=\"w-5 h-5 text-rose-500 fill-rose-500/10\" />\n            Patient Assessment Intake\n          </h2>\n          <p className=\"text-xs text-slate-500 mt-1\">Input individual clinical indicators to evaluate heart failure prediction.</p>\n        </div>\n        <button\n          type=\"button\"\n          id=\"btn_random_patient\"\n          onClick={generateRandomDemo}\n          className=\"text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 active:bg-blue-200 px-3 py-2 rounded-lg flex items-center justify-center gap-1.5 transition-colors self-start sm:self-center cursor-pointer\"\n        >\n          <RefreshCw className=\"w-3.5 h-3.5\" />\n          Load Random Case\n        </button>\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"space-y-6\">\n        {/* Row 1: Identification & Demographics */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-5\">\n          <div className=\"flex flex-col gap-1.5\">\n            <label htmlFor=\"patient_name\" className=\"text-xs font-semibold text-slate-700\">Patient Full Name</label>\n            <input\n              type=\"text\"\n              id=\"patient_name\"\n              placeholder=\"e.g. John Doe (Optional)\"\n              value={formData.name}\n              onChange={(e) => setFormData({ ...formData, name: e.target.value })}\n              className=\"px-3.5 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 text-slate-800\"\n            />\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <label htmlFor=\"patient_age\" className=\"text-xs font-semibold text-slate-700\">Age: <span className=\"text-blue-600 font-bold\">{formData.age} yrs</span></label>\n            <div className=\"flex items-center gap-3\">\n              <input\n                type=\"range\"\n                id=\"patient_age\"\n                min=\"1\"\n                max=\"105\"\n                value={formData.age}\n                onChange={(e) => setFormData({ ...formData, age: Number(e.target.value) })}\n                className=\"w-full accent-blue-600 h-1.5 bg-slate-100 rounded-lg cursor-pointer\"\n              />\n              <input\n                type=\"number\"\n                min=\"1\"\n                max=\"105\"\n                value={formData.age}\n                onChange={(e) => setFormData({ ...formData, age: Math.min(105, Math.max(1, Number(e.target.value))) })}\n                className=\"w-16 px-2 py-1 text-xs border border-slate-200 rounded-lg text-center font-medium text-slate-700 focus:outline-hidden focus:border-blue-500 focus:ring-1 focus:ring-blue-500\"\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <span className=\"text-xs font-semibold text-slate-700\">Sex Assigned at Birth</span>\n            <div className=\"grid grid-cols-2 gap-2 bg-slate-50 p-1 rounded-xl border border-slate-100\">\n              <button\n                type=\"button\"\n                id=\"btn_sex_m\"\n                onClick={() => setFormData({ ...formData, sex: \'M\' })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.sex === \'M\'\n                    ? \'bg-white text-blue-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                Male (M)\n              </button>\n              <button\n                type=\"button\"\n                id=\"btn_sex_f\"\n                onClick={() => setFormData({ ...formData, sex: \'F\' })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.sex === \'F\'\n                    ? \'bg-white text-rose-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                Female (F)\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Row 2: Vitals & Lab results */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-5\">\n          <div className=\"flex flex-col gap-1.5\">\n            <label htmlFor=\"resting_bp\" className=\"text-xs font-semibold text-slate-700\">\n              Resting BP <span className=\"text-slate-400 font-normal\">(mmHg)</span>: <span className=\"text-blue-600 font-bold\">{formData.restingBP}</span>\n            </label>\n            <div className=\"flex items-center gap-3\">\n              <input\n                type=\"range\"\n                id=\"resting_bp\"\n                min=\"80\"\n                max=\"210\"\n                value={formData.restingBP}\n                onChange={(e) => setFormData({ ...formData, restingBP: Number(e.target.value) })}\n                className=\"w-full accent-blue-600 h-1.5 bg-slate-100 rounded-lg cursor-pointer\"\n              />\n              <input\n                type=\"number\"\n                min=\"60\"\n                max=\"250\"\n                value={formData.restingBP}\n                onChange={(e) => setFormData({ ...formData, restingBP: Math.min(250, Math.max(40, Number(e.target.value))) })}\n                className=\"w-16 px-2 py-1 text-xs border border-slate-200 rounded-lg text-center font-medium text-slate-700 focus:outline-hidden focus:border-blue-500 focus:ring-1 focus:ring-blue-500\"\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <label htmlFor=\"serum_cholesterol\" className=\"text-xs font-semibold text-slate-700\">\n              Serum Cholesterol <span className=\"text-slate-400 font-normal\">(mg/dl)</span>: <span className=\"text-blue-600 font-bold\">{formData.cholesterol === 0 ? \'0 (Unrecorded)\' : formData.cholesterol}</span>\n            </label>\n            <div className=\"flex items-center gap-3\">\n              <input\n                type=\"range\"\n                id=\"serum_cholesterol\"\n                min=\"0\"\n                max=\"500\"\n                value={formData.cholesterol}\n                onChange={(e) => setFormData({ ...formData, cholesterol: Number(e.target.value) })}\n                className=\"w-full accent-blue-600 h-1.5 bg-slate-100 rounded-lg cursor-pointer\"\n              />\n              <input\n                type=\"number\"\n                min=\"0\"\n                max=\"600\"\n                value={formData.cholesterol}\n                onChange={(e) => setFormData({ ...formData, cholesterol: Math.min(600, Math.max(0, Number(e.target.value))) })}\n                className=\"w-16 px-2 py-1 text-xs border border-slate-200 rounded-lg text-center font-medium text-slate-700 focus:outline-hidden focus:border-blue-500 focus:ring-1 focus:ring-blue-500\"\n              />\n            </div>\n            <p className=\"text-[10px] text-slate-400\">Note: 0 indicates missing baseline sample in the clinical dataset.</p>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <span className=\"text-xs font-semibold text-slate-700\">Fasting Blood Sugar</span>\n            <div className=\"grid grid-cols-2 gap-2 bg-slate-50 p-1 rounded-xl border border-slate-100\">\n              <button\n                type=\"button\"\n                id=\"btn_fasting_normal\"\n                onClick={() => setFormData({ ...formData, fastingBS: 0 })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.fastingBS === 0\n                    ? \'bg-white text-emerald-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                \342\211\244 120 mg/dl\n              </button>\n              <button\n                type=\"button\"\n                id=\"btn_fasting_elevated\"\n                onClick={() => setFormData({ ...formData, fastingBS: 1 })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.fastingBS === 1\n                    ? \'bg-white text-amber-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                &gt; 120 mg/dl (Diabetic)\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Row 3: Cardiac pain descriptors */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n          <div className=\"flex flex-col gap-1.5\">\n            <label htmlFor=\"pain_type_select\" className=\"text-xs font-semibold text-slate-700\">Chest Pain Type</label>\n            <select\n              id=\"pain_type_select\"\n              value={formData.chestPainType}\n              onChange={(e) => setFormData({ ...formData, chestPainType: e.target.value as any })}\n              className=\"px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 bg-white text-slate-800 font-medium\"\n            >\n              <option value=\"ASY\">Asymptomatic (ASY) \342\200\224 Silent Ischemia / Highly Correlated with Pathology</option>\n              <option value=\"TA\">Typical Angina (TA) \342\200\224 Left Chest Radiating Pressure</option>\n              <option value=\"ATA\">Atypical Angina (ATA) \342\200\224 Intermittent Discomfort</option>\n              <option value=\"NAP\">Non-Anginal Pain (NAP) \342\200\224 Pleuritic or Local Musculoskeletal</option>\n            </select>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <span className=\"text-xs font-semibold text-slate-700\">Exercise-Induced Angina</span>\n            <div className=\"grid grid-cols-2 gap-2 bg-slate-50 p-1 rounded-xl border border-slate-100\">\n              <button\n                type=\"button\"\n                id=\"btn_angina_n\"\n                onClick={() => setFormData({ ...formData, exerciseAngina: \'N\' })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.exerciseAngina === \'N\'\n                    ? \'bg-white text-emerald-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                No Angina (N)\n              </button>\n              <button\n                type=\"button\"\n                id=\"btn_angina_y\"\n                onClick={() => setFormData({ ...formData, exerciseAngina: \'Y\' })}\n                className={`py-1.5 text-xs font-semibold rounded-lg transition-colors cursor-pointer ${\n                  formData.exerciseAngina === \'Y\'\n                    ? \'bg-white text-rose-700 shadow-xs border border-slate-200/50\'\n                    : \'text-slate-500 hover:text-slate-800\'\n                }`}\n              >\n                Angina Developed (Y)\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Row 4: Stress ECG markers (MaxHR, Oldpeak, ST_Slope / RestECG) */}\n        <div className=\"p-4 bg-slate-50 rounded-xl border border-slate-100/80 space-y-5\">\n          <span className=\"text-xs font-bold text-slate-800 tracking-wide uppercase flex items-center gap-1.5\">\n            <span className=\"w-1.5 h-3 bg-blue-600 rounded-xs\"></span>\n            Electrocardiogram (ECG) & Active Stress Test Diagnostics\n          </span>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n            <div className=\"flex flex-col gap-1.5 font-sans\">\n              <label htmlFor=\"rest_ecg_select\" className=\"text-xs font-semibold text-slate-700\">Resting ECG Results</label>\n              <select\n                id=\"rest_ecg_select\"\n                value={formData.restingECG}\n                onChange={(e) => setFormData({ ...formData, restingECG: e.target.value as any })}\n                className=\"px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 bg-white text-slate-800\"\n              >\n                <option value=\"Normal\">Normal \342\200\224 Clear electrical activity rhythm</option>\n                <option value=\"ST\">ST Deviation \342\200\224 ST-T wave abnormalities (Myocardial fatigue)</option>\n                <option value=\"LVH\">LVH \342\200\224 Left Ventricular Hypertrophy (Voltage criteria cardiac load)</option>\n              </select>\n            </div>\n\n            <div className=\"flex flex-col gap-1.5\">\n              <label htmlFor=\"st_slope_select\" className=\"text-xs font-semibold text-slate-700\">Peak Exercise ST-Slope</label>\n              <select\n                id=\"st_slope_select\"\n                value={formData.stSlope}\n                onChange={(e) => setFormData({ ...formData, stSlope: e.target.value as any })}\n                className=\"px-3 py-2 text-sm border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 bg-white text-slate-800 font-medium\"\n              >\n                <option value=\"Up\">Upsloping (Up) \342\200\224 Normal coronary acceleration response</option>\n                <option value=\"Flat\">Flat (Flat) \342\200\224 Chronic sub-ischemic pattern (Risk Marker)</option>\n                <option value=\"Down\">Downsloping (Down) \342\200\224 High probability acute ischemia (Critical Risk)</option>\n              </select>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5 pt-1\">\n            <div className=\"flex flex-col gap-1.5\">\n              <label htmlFor=\"max_stress_hr\" className=\"text-xs font-semibold text-slate-700\">\n                Max achieved Heart Rate <span className=\"text-slate-400 font-normal\">(BPM)</span>: <span className=\"text-blue-600 font-bold\">{formData.maxHR} bpm</span>\n              </label>\n              <div className=\"flex items-center gap-3\">\n                <input\n                  type=\"range\"\n                  id=\"max_stress_hr\"\n                  min=\"60\"\n                  max=\"202\"\n                  value={formData.maxHR}\n                  onChange={(e) => setFormData({ ...formData, maxHR: Number(e.target.value) })}\n                  className=\"w-full accent-blue-600 h-1.5 bg-slate-200 rounded-lg cursor-pointer\"\n                />\n                <input\n                  type=\"number\"\n                  min=\"50\"\n                  max=\"220\"\n                  value={formData.maxHR}\n                  onChange={(e) => setFormData({ ...formData, maxHR: Math.min(220, Math.max(40, Number(e.target.value))) })}\n                  className=\"w-16 px-2 py-1 text-xs border border-slate-200 rounded-lg text-center font-medium text-slate-700 focus:outline-hidden focus:border-blue-500 focus:ring-1 focus:ring-blue-500\"\n                />\n              </div>\n            </div>\n\n            <div className=\"flex flex-col gap-1.5\">\n              <label htmlFor=\"oldpeak_stress\" className=\"text-xs font-semibold text-slate-700\">\n                Oldpeak ST Depression <span className=\"text-slate-400 font-normal\">(mm scale)</span>: <span className=\"text-blue-600 font-bold\">{formData.oldpeak} mm</span>\n              </label>\n              <div className=\"flex items-center gap-3\">\n                <input\n                  type=\"range\"\n                  id=\"oldpeak_stress\"\n                  min=\"0.0\"\n                  max=\"6.2\"\n                  step=\"0.1\"\n                  value={formData.oldpeak}\n                  onChange={(e) => setFormData({ ...formData, oldpeak: Number(e.target.value) })}\n                  className=\"w-full accent-blue-600 h-1.5 bg-slate-200 rounded-lg cursor-pointer\"\n                />\n                <input\n                  type=\"number\"\n                  min=\"0\"\n                  max=\"10\"\n                  step=\"0.1\"\n                  value={formData.oldpeak}\n                  onChange={(e) => setFormData({ ...formData, oldpeak: Math.min(10, Math.max(0, Number(e.target.value))) })}\n                  className=\"w-16 px-2 py-1 text-xs border border-slate-200 rounded-lg text-center font-medium text-slate-700 focus:outline-hidden focus:border-blue-500 focus:ring-1 focus:ring-blue-500\"\n                />\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Form Action */}\n        <div className=\"flex justify-end pt-2\">\n          <button\n            type=\"submit\"\n            id=\"btn_execute_prediction\"\n            className=\"px-6 py-2.5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-medium rounded-xl text-sm shadow-xs hover:shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer\"\n          >\n            <UserPlus className=\"w-4 h-4\" />\n            Calculate & Add Patient Risk\n          </button>\n        </div>\n      </form>\n    </div>\n  );\n}\n"
    }
    overwrite: true
  }
}
