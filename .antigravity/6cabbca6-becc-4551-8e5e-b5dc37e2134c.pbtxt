        }
        lines {
          text: "      name: formData.name.trim() || `Patient #${Math.floor(Math.random() * 9000) + 1000}`,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      prediction: {"
