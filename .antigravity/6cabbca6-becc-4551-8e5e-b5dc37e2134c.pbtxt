    instruction: "Translate all clinical risk factors and diagnostic messages inside predictor.ts to Indonesian."
    replacement_infos {
      original_chunk {
        target_content: "export function predictHeartDisease(patient: Omit<PatientRecord, \'prediction\'>): PredictionResult {\n  let score = 15; // Base probability percentage\n  const indicators: PredictionResult[\'indicators\'] = [];\n  const riskFactors: PredictionResult[\'riskFactors\'] = [];\n\n  // 1. ST Slope (The single strongest visual predictor in the dataset)\n  if (patient.stSlope === \'Down\') {\n    score += 32;\n    riskFactors.push({\n      factor: \'Downsloping ST Segment\',\n      impact: \'High\',\n      description: \'Downsloping ST slope is a strong indicator of severe myocardial ischemia or coronary artery narrowing.\'\n    });\n    indicators.push({\n      name: \'ST Segment Slope\',\n      value: \'Downsloping\',\n      status: \'critical\',\n      message: \'Indicates high probability of acute ischemia or left ventricular strain.\'\n    });\n  } else if (patient.stSlope === \'Flat\') {\n    score += 24;\n    riskFactors.push({\n      factor: \'Flat ST Segment\',\n      impact: \'High\',\n      description: \'A flat ST segment slope represents standard diagnostic indicator of coronary stenosis or ischemia.\'\n    });\n    indicators.push({\n      name: \'ST Segment Slope\',\n      value: \'Flat\',\n      status: \'warning\',\n      message: \'Often correlates with coronary artery disease and decreased coronary reserve.\'\n    });\n  } else {\n    score -= 15;\n    indicators.push({\n      name: \'ST Segment Slope\',\n      value: \'Upsloping\',\n      status: \'normal\',\n      message: \'Typically healthy or normal response to stress testing.\'\n    });\n  }\n\n  // 2. Exercise Induced Angina\n  if (patient.exerciseAngina === \'Y\') {\n    score += 22;\n    riskFactors.push({\n      factor: \'Exercise-Induced Angina\',\n      impact: \'High\',\n      description: \'Development of chest constriction or pain during physical exertion is strongly diagnostic of coronary atherosclerosis.\'\n    });\n    indicators.push({\n      name: \'Exercise Angina\',\n      value: \'Yes\',\n      status: \'critical\',\n      message: \'Positive stress angina confirms myocardial oxygen demand is exceeding supply.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Exercise Angina\',\n      value: \'No\',\n      status: \'normal\',\n      message: \'No abnormal cardiac pain induced by physical exertion.\'\n    });\n  }\n\n  // 3. Chest Pain Type\n  // ASY: Asymptomatic (In this dataset, ASY chest pain is strongly correlated with cardiac disease, signifying silent hypoxia/referred pain)\n  if (patient.chestPainType === \'ASY\') {\n    score += 20;\n    riskFactors.push({\n      factor: \'Asymptomatic Chest Presentation\',\n      impact: \'High\',\n      description: \'Statistically associated with silent ischemic heart disease and delayed clinical reporting.\'\n    });\n    indicators.push({\n      name: \'Chest Pain Type\',\n      value: \'Asymptomatic (ASY)\',\n      status: \'warning\',\n      message: \'In risk groups, lack of classic pain often results in silent coronary progression.\'\n    });\n  } else if (patient.chestPainType === \'TA\') {\n    score += 12;\n    riskFactors.push({\n      factor: \'Typical Angina (TA)\',\n      impact: \'Medium\',\n      description: \'Classic cardiac chest pain with radiation, highly suggestive of ischemic pathology.\'\n    });\n    indicators.push({\n      name: \'Chest Pain Type\',\n      value: \'Typical Angina\',\n      status: \'warning\',\n      message: \'Classic pressure or tightness indicating provisional coronary restriction.\'\n    });\n  } else if (patient.chestPainType === \'NAP\') {\n    score += 5;\n    indicators.push({\n      name: \'Chest Pain Type\',\n      value: \'Non-Anginal (NAP)\',\n      status: \'normal\',\n      message: \'Chest pain unlikely related to cardiac artery narrowing.\'\n    });\n  } else { // ATA\n    score += 2;\n    indicators.push({\n      name: \'Chest Pain Type\',\n      value: \'Atypical Angina (ATA)\',\n      status: \'normal\',\n      message: \'Uncharacteristic chest discomfort, minimal clinical association.\'\n    });\n  }\n\n  // 4. Oldpeak (ST depression induced by exercise relative to rest)\n  if (patient.oldpeak >= 2.0) {\n    score += 28;\n    riskFactors.push({\n      factor: \'Severe ST Depression (Oldpeak)\',\n      impact: \'High\',\n      description: \'ST depression of 2.0+ mm indicates severe exercise-induced myocardial hypoxia.\'\n    });\n    indicators.push({\n      name: \'ST Depression (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'critical\',\n      message: \'Significant ST depression represents severe risk of multivessel coronary obstruction.\'\n    });\n  } else if (patient.oldpeak > 0.8) {\n    score += 14;\n    riskFactors.push({\n      factor: \'Moderate ST Depression\',\n      impact: \'Medium\',\n      description: \'ST depression above 0.8 mm indicates noticeable subendocardial ischemia during workload.\'\n    });\n    indicators.push({\n      name: \'ST Depression (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'warning\',\n      message: \'Moderate ST depression suggesting early cardiovascular ischemia.\'\n    });\n  } else {\n    indicators.push({\n      name: \'ST Depression (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'normal\',\n      message: \'Normal or nominal ST segment baseline recovery.\'\n    });\n  }\n\n  // 5. Sex\n  if (patient.sex === \'M\') {\n    score += 10;\n    indicators.push({\n      name: \'Demographic Factor\',\n      value: \'Male Sex\',\n      status: \'normal\',\n      message: \'Men have a statistically earlier onset of cardiovascular events in global registries.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Demographic Factor\',\n      value: \'Female Sex\',\n      status: \'normal\',\n      message: \'Statistically lower early cardiovascular risk, though risk rises post-menopause.\'\n    });\n  }\n\n  // 6. Age\n  if (patient.age > 65) {\n    score += 15;\n    riskFactors.push({\n      factor: \'Geriatric Cardiac Profile\',\n      impact: \'Medium\',\n      description: \'Advanced age (>65) naturally corresponds with systemic arterial stiffness and coronary calcification.\'\n    });\n  } else if (patient.age > 50) {\n    score += 8;\n  } else if (patient.age < 40) {\n    score -= 8;\n  }\n\n  // 7. Max Heart Rate Achieved (MaxHR)\n  if (patient.maxHR < 120) {\n    score += 16;\n    riskFactors.push({\n      factor: \'Chronotropic Incompetence (Low MaxHR)\',\n      impact: \'Medium\',\n      description: \'Failure to achieve peak cardiac pacing under stress is associated with autonomic or heart muscle dysregulation.\'\n    });\n    indicators.push({\n      name: \'Max Heart Rate\',\n      value: `${patient.maxHR} bpm`,\n      status: \'critical\',\n      message: \'Low maximum heart rate under load suggests chronotropic incompetence.\'\n    });\n  } else if (patient.maxHR < 140) {\n    score += 8;\n    indicators.push({\n      name: \'Max Heart Rate\',\n      value: `${patient.maxHR} bpm`,\n      status: \'warning\',\n      message: \'Sub-optimal workload heart-rate capacity.\'\n    });\n  } else {\n    score -= 5;\n    indicators.push({\n      name: \'Max Heart Rate\',\n      value: `${patient.maxHR} bpm`,\n      status: \'normal\',\n      message: \'Good cardiac acceleration capacity.\'\n    });\n  }\n\n  // 8. Resting Blood Pressure (RestingBP)\n  if (patient.restingBP >= 160) {\n    score += 14;\n    riskFactors.push({\n      factor: \'Stage 2 Hypertension\',\n      impact: \'High\',\n      description: \'Severe hypertension (>160 mmHg) exponentially increases vascular resistance and clinical work on left ventricle.\'\n    });\n    indicators.push({\n      name: \'Resting Blood Pressure\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'critical\',\n      message: \'Severe resting hypertension causes myocardial hypertrophy and arterial injury.\'\n    });\n  } else if (patient.restingBP >= 140) {\n    score += 8;\n    riskFactors.push({\n      factor: \'Stage 1 Hypertension\',\n      impact: \'Medium\',\n      description: \'Consistent pressure above 140 mmHg causes cumulative endothelial shear strain.\'\n    });\n    indicators.push({\n      name: \'Resting Blood Pressure\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'warning\',\n      message: \'Elevated blood pressure indicates chronic vascular overload.\'\n    });\n  } else if (patient.restingBP < 90 && patient.restingBP > 0) {\n    indicators.push({\n      name: \'Resting Blood Pressure\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'warning\',\n      message: \'Hypotension (low blood pressure) may point to cardiac pump depletion.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Resting Blood Pressure\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'normal\',\n      message: \'Healthy normotensive blood pressure range.\'\n    });\n  }\n\n  // 9. Cholesterol and the special Kaggle Zero value\n  if (patient.cholesterol === 0) {\n    // Statistically, 0 represents a structural missing data indicator,\n    // which significantly clusters with cardiac patients in specific datasets.\n    score += 12;\n    riskFactors.push({\n      factor: \'Unrecorded / Undetected Cholesterol\',\n      impact: \'Medium\',\n      description: \'Cholesterol coded as 0 represents standard missing records, statistically clustering with clinical emergency admissions.\'\n    });\n    indicators.push({\n      name: \'Serum Cholesterol\',\n      value: \'Unrecorded\',\n      status: \'warning\',\n      message: \'No recorded cholesterol baseline. Statistically clusters with high-acuity historic cohorts.\'\n    });\n  } else if (patient.cholesterol >= 240) {\n    score += 10;\n    riskFactors.push({\n      factor: \'Hypercholesterolemia\',\n      impact: \'Medium\',\n      description: \'Serum cholesterol above 240 mg/dl is highly atherogenic and accelerates coronary plaque deposition.\'\n    });\n    indicators.push({\n      name: \'Serum Cholesterol\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'critical\',\n      message: \'High serum cholesterol increases core cardiovascular atherogenesis.\'\n    });\n  } else if (patient.cholesterol >= 200) {\n    score += 5;\n    indicators.push({\n      name: \'Serum Cholesterol\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'warning\',\n      message: \'Borderline elevated cholesterol level.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Serum Cholesterol\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'normal\',\n      message: \'Optimal cholesterol limits (under 200 mg/dl).\'\n    });\n  }\n\n  // 10. Fasting Blood Sugar (FastingBS)\n  if (patient.fastingBS === 1) {\n    score += 12;\n    riskFactors.push({\n      factor: \'Hyperglycemia / Diabetes Mellitus\',\n      impact: \'Medium\',\n      description: \'Elevated fasting blood sugar exceeds healthy metabolic thresholds, damaging vascular walls and coronary microvasculature.\'\n    });\n    indicators.push({\n      name: \'Fasting Blood Sugar\',\n      value: \'> 120 mg/dl\',\n      status: \'warning\',\n      message: \'Signals poor glucose tolerance or active diabetes, a major accelerator for coronary diseases.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Fasting Blood Sugar\',\n      value: \'\342\211\244 120 mg/dl\',\n      status: \'normal\',\n      message: \'Healthy fasting glycemic profile.\'\n    });\n  }\n\n  // 11. Resting ECG\n  if (patient.restingECG === \'ST\') {\n    score += 10;\n    riskFactors.push({\n      factor: \'Abnormal ST-T wave ECG Profile\',\n      impact: \'Medium\',\n      description: \'Resting ECG showing ST-T wave abnormalities is a predictor of underlying structural heart anomalies.\'\n    });\n    indicators.push({\n      name: \'Resting ECG\',\n      value: \'ST-T Wave Abnormality\',\n      status: \'critical\',\n      message: \'Resting electro-abnormalities pointing to potential cardiac sub-hypoxia.\'\n    });\n  } else if (patient.restingECG === \'LVH\') {\n    score += 12;\n    riskFactors.push({\n      factor: \'Left Ventricular Hypertrophy (LVH)\',\n      impact: \'Medium\',\n      description: \'Thickened left chamber walls indicated by LVH point to sustained pressure load or hypertrophy.\'\n    });\n    indicators.push({\n      name: \'Resting ECG\',\n      value: \'LVH (Chamber strain)\',\n      status: \'warning\',\n      message: \'Evidence of chronic high-load hypertrophy of the left ventricle.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Resting ECG\',\n      value: \'Normal\',\n      status: \'normal\',\n      message: \'Healthy baseline resting electrical rhythm.\'\n    });\n  }\n\n  // Cap the final percentage realistically\n  const finalProbability = Math.max(2, Math.min(98, score));\n\n  let riskLevel: PredictionResult[\'riskLevel\'] = \'Low\';\n  if (finalProbability >= 82) {\n    riskLevel = \'Critical\';\n  } else if (finalProbability >= 60) {\n    riskLevel = \'High\';\n  } else if (finalProbability >= 30) {\n    riskLevel = \'Moderate\';\n  }\n\n  return {\n    heartDiseaseProbability: Math.round(finalProbability),\n    riskLevel,\n    riskFactors,\n    indicators\n  };\n}"
        replacement_content: "export function predictHeartDisease(patient: Omit<PatientRecord, \'prediction\'>): PredictionResult {\n  let score = 15; // Base probability percentage\n  const indicators: PredictionResult[\'indicators\'] = [];\n  const riskFactors: PredictionResult[\'riskFactors\'] = [];\n\n  // 1. ST Slope (The single strongest visual predictor in the dataset)\n  if (patient.stSlope === \'Down\') {\n    score += 32;\n    riskFactors.push({\n      factor: \'Kemiringan ST Menurun (Downsloping)\',\n      impact: \'High\',\n      description: \'Kemiringan ST menurun merupakan indikator kuat adanya iskemia miokardial berat atau penyempitan arteri koroner.\'\n    });\n    indicators.push({\n      name: \'Kemiringan Segmen ST\',\n      value: \'Menurun (Downsloping)\',\n      status: \'critical\',\n      message: \'Menunjukkan kemungkinan tinggi terjadinya iskemia akut atau regangan ventrikel kiri.\'\n    });\n  } else if (patient.stSlope === \'Flat\') {\n    score += 24;\n    riskFactors.push({\n      factor: \'Kemiringan ST Datar (Flat)\',\n      impact: \'High\',\n      description: \'Kemiringan segmen ST yang datar merupakan indikator diagnostik standar dari stenosis koroner atau iskemia.\'\n    });\n    indicators.push({\n      name: \'Kemiringan Segmen ST\',\n      value: \'Datar (Flat)\',\n      status: \'warning\',\n      message: \'Seringkali berkorelasi dengan penyakit arteri koroner dan penurunan cadangan aliran koroner.\'\n    });\n  } else {\n    score -= 15;\n    indicators.push({\n      name: \'Kemiringan Segmen ST\',\n      value: \'Menanjak (Upsloping)\',\n      status: \'normal\',\n      message: \'Biasanya merupakan respons sehat atau normal terhadap tes beban jantung.\'\n    });\n  }\n\n  // 2. Exercise Induced Angina\n  if (patient.exerciseAngina === \'Y\') {\n    score += 22;\n    riskFactors.push({\n      factor: \'Angina Akibat Aktivitas Fisik\',\n      impact: \'High\',\n      description: \'Timbulnya rasa nyeri atau sesak di dada selama aktivitas fisik sangat berkaitan dengan diagnosis aterosklerosis koroner.\'\n    });\n    indicators.push({\n      name: \'Angina Akibat Latihan\',\n      value: \'Ya (Ada)\',\n      status: \'critical\',\n      message: \'Rasa nyeri dada saat latihan menegaskan bahwa kebutuhan oksigen otot jantung melebihi pasokan.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Angina Akibat Latihan\',\n      value: \'Tidak Ada\',\n      status: \'normal\',\n      message: \'Tidak ada nyeri dada abnormal yang dipicu oleh aktivitas fisik.\'\n    });\n  }\n\n  // 3. Chest Pain Type\n  if (patient.chestPainType === \'ASY\') {\n    score += 20;\n    riskFactors.push({\n      factor: \'Gejala Nyeri Dada Asimtomatik (ASY)\',\n      impact: \'High\',\n      description: \'Secara statistik sangat berkaitan dengan penyakit jantung iskemia senyap (silent ischemia) dan keterlambatan pelaporan klinis.\'\n    });\n    indicators.push({\n      name: \'Tipe Nyeri Dada\',\n      value: \'Asimtomatik (ASY)\',\n      status: \'warning\',\n      message: \'Pada kelompok berisiko, kurangnya rasa nyeri klasik sering kali menyebabkan penyakit koroner berkembang tanpa disadari.\'\n    });\n  } else if (patient.chestPainType === \'TA\') {\n    score += 12;\n    riskFactors.push({\n      factor: \'Angina Tipikal (TA)\',\n      impact: \'Medium\',\n      description: \'Nyeri dada jantung klasik yang menjalar, sangat menunjukkan adanya patologi iskemia.\'\n    });\n    indicators.push({\n      name: \'Tipe Nyeri Dada\',\n      value: \'Angina Tipikal (TA)\',\n      status: \'warning\',\n      message: \'Rasa tertekan atau sesak klasik yang menunjukkan adanya penyumbatan koroner sementara.\'\n    });\n  } else if (patient.chestPainType === \'NAP\') {\n    score += 5;\n    indicators.push({\n      name: \'Tipe Nyeri Dada\',\n      value: \'Nyeri Non-Anginal (NAP)\',\n      status: \'normal\',\n      message: \'Nyeri dada yang kemungkinan besar tidak terkait dengan penyempitan arteri jantung.\'\n    });\n  } else { // ATA\n    score += 2;\n    indicators.push({\n      name: \'Tipe Nyeri Dada\',\n      value: \'Angina Atipikal (ATA)\',\n      status: \'normal\',\n      message: \'Ketidaknyamanan dada yang tidak khas, korelasi klinis minimal.\'\n    });\n  }\n\n  // 4. Oldpeak (ST depression induced by exercise relative to rest)\n  if (patient.oldpeak >= 2.0) {\n    score += 28;\n    riskFactors.push({\n      factor: \'Depresi ST Berat (Oldpeak)\',\n      impact: \'High\',\n      description: \'Depresi segmen ST sebesar 2.0+ mm menunjukkan hipoksia miokardial yang parah akibat aktivitas fisik.\'\n    });\n    indicators.push({\n      name: \'Depresi ST (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'critical\',\n      message: \'Depresi ST yang signifikan menunjukkan risiko tinggi penyumbatan arteri koroner multi-pembuluh darah.\'\n    });\n  } else if (patient.oldpeak > 0.8) {\n    score += 14;\n    riskFactors.push({\n      factor: \'Depresi ST Sedang\',\n      impact: \'Medium\',\n      description: \'Depresi ST di atas 0.8 mm menunjukkan adanya iskemia subendokardial yang terlihat selama beban kerja jantung.\'\n    });\n    indicators.push({\n      name: \'Depresi ST (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'warning\',\n      message: \'Depresi ST sedang menunjukkan tanda awal iskemia kardiovaskular.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Depresi ST (Oldpeak)\',\n      value: `${patient.oldpeak} mm`,\n      status: \'normal\',\n      message: \'Pemulihan baseline segmen ST yang normal atau nominal.\'\n    });\n  }\n\n  // 5. Sex\n  if (patient.sex === \'M\') {\n    score += 10;\n    indicators.push({\n      name: \'Faktor Demografi\',\n      value: \'Pria\',\n      status: \'normal\',\n      message: \'Pria secara statistik memiliki onset penyakit kardiovaskular yang lebih awal dalam registrasi global.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Faktor Demografi\',\n      value: \'Wanita\',\n      status: \'normal\',\n      message: \'Secara statistik memiliki risiko kardiovaskular awal yang lebih rendah, meskipun risiko meningkat setelah menopause.\'\n    });\n  }\n\n  // 6. Age\n  if (patient.age > 65) {\n    score += 15;\n    riskFactors.push({\n      factor: \'Profil Jantung Geriatri\',\n      impact: \'Medium\',\n      description: \'Usia lanjut (>65 tahun) secara alami berkorelasi dengan kekakuan arteri sistemik dan kalsifikasi koroner.\'\n    });\n  } else if (patient.age > 50) {\n    score += 8;\n  } else if (patient.age < 40) {\n    score -= 8;\n  }\n\n  // 7. Max Heart Rate Achieved (MaxHR)\n  if (patient.maxHR < 120) {\n    score += 16;\n    riskFactors.push({\n      factor: \'Inkompetensi Kronotropik (MaxHR Rendah)\',\n      impact: \'Medium\',\n      description: \'Kegagalan mencapai denyut jantung puncak saat aktivitas stres berhubungan dengan disfungsi otot jantung atau saraf otonom.\'\n    });\n    indicators.push({\n      name: \'Detak Jantung Maksimal\',\n      value: `${patient.maxHR} bpm`,\n      status: \'critical\',\n      message: \'Detak jantung maksimal yang rendah di bawah beban latihan menunjukkan inkompetensi kronotropik.\'\n    });\n  } else if (patient.maxHR < 140) {\n    score += 8;\n    indicators.push({\n      name: \'Detak Jantung Maksimal\',\n      value: `${patient.maxHR} bpm`,\n      status: \'warning\',\n      message: \'Kapasitas detak jantung nominal di bawah tingkat latihan optimal.\'\n    });\n  } else {\n    score -= 5;\n    indicators.push({\n      name: \'Detak Jantung Maksimal\',\n      value: `${patient.maxHR} bpm`,\n      status: \'normal\',\n      message: \'Kapasitas akselerasi jantung yang sehat dan responsif.\'\n    });\n  }\n\n  // 8. Resting Blood Pressure (RestingBP)\n  if (patient.restingBP >= 160) {\n    score += 14;\n    riskFactors.push({\n      factor: \'Hipertensi Tahap 2\',\n      impact: \'High\',\n      description: \'Hipertensi berat (>160 mmHg) secara eksponensial meningkatkan resistensi pembuluh darah dan beban kerja ventrikel kiri.\'\n    });\n    indicators.push({\n      name: \'Tekanan Darah Istirahat\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'critical\',\n      message: \'Hipertensi istirahat berat dapat menyebabkan hipertrofi miokardial dan cedera arteri.\'\n    });\n  } else if (patient.restingBP >= 140) {\n    score += 8;\n    riskFactors.push({\n      factor: \'Hipertensi Tahap 1\',\n      impact: \'Medium\',\n      description: \'Tekanan darah konsisten di atas 140 mmHg menyebabkan ketegangan geser endotelial kumulatif.\'\n    });\n    indicators.push({\n      name: \'Tekanan Darah Istirahat\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'warning\',\n      message: \'Tekanan darah tinggi menunjukkan kelebihan beban pembuluh darah yang kronis.\'\n    });\n  } else if (patient.restingBP < 90 && patient.restingBP > 0) {\n    indicators.push({\n      name: \'Tekanan Darah Istirahat\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'warning\',\n      message: \'Hipotensi (tekanan darah rendah) dapat mengindikasikan penurunan fungsi pompa otot jantung.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Tekanan Darah Istirahat\',\n      value: `${patient.restingBP} mmHg`,\n      status: \'normal\',\n      message: \'Rentang tekanan darah normotensif yang sehat.\'\n    });\n  }\n\n  // 9. Cholesterol and the special Kaggle Zero value\n  if (patient.cholesterol === 0) {\n    score += 12;\n    riskFactors.push({\n      factor: \'Kolesterol Tidak Tercatat / Tidak Terdeteksi\',\n      impact: \'Medium\',\n      description: \'Kolesterol berkode 0 mewakili data yang hilang pada pencatatan klinis, secara statistik berkerumun dengan kelompok perawatan darurat.\'\n    });\n    indicators.push({\n      name: \'Kolesterol Serum\',\n      value: \'Tidak Tercatat\',\n      status: \'warning\',\n      message: \'Tidak ada data dasar kolesterol yang tercatat. Secara statistik berkelompok dengan admisi klinis berisiko tinggi sebelumnya.\'\n    });\n  } else if (patient.cholesterol >= 240) {\n    score += 10;\n    riskFactors.push({\n      factor: \'Hiperkolesterolemia\',\n      impact: \'Medium\',\n      description: \'Kolesterol serum di atas 240 mg/dl sangat bersifat aterogenik dan mempercepat pengendapan plak koroner.\'\n    });\n    indicators.push({\n      name: \'Kolesterol Serum\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'critical\',\n      message: \'Kolesterol serum yang tinggi meningkatkan aterogenesis kardiovaskular inti.\'\n    });\n  } else if (patient.cholesterol >= 200) {\n    score += 5;\n    indicators.push({\n      name: \'Kolesterol Serum\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'warning\',\n      message: \'Kadar kolesterol sedikit meningkat (ambas batas atas).\'\n    });\n  } else {\n    indicators.push({\n      name: \'Kolesterol Serum\',\n      value: `${patient.cholesterol} mg/dl`,\n      status: \'normal\',\n      message: \'Kadar kolesterol dalam batas optimal (di bawah 200 mg/dl).\'\n    });\n  }\n\n  // 10. Fasting Blood Sugar (FastingBS)\n  if (patient.fastingBS === 1) {\n    score += 12;\n    riskFactors.push({\n      factor: \'Hiperglisemia / Diabetes Melitus\',\n      impact: \'Medium\',\n      description: \'Gula darah puasa yang tinggi melebihi ambang batas metabolik sehat, merusak dinding pembuluh darah serta mikrovaskular koroner.\'\n    });\n    indicators.push({\n      name: \'Gula Darah Puasa\',\n      value: \'> 120 mg/dl\',\n      status: \'warning\',\n      message: \'Menandakan toleransi glukosa yang buruk atau diabetes aktif, pemicu utama penyakit arteri koroner.\'\n    });\n  } else {\n    indicators.push({\n      name: \'Gula Darah Puasa\',\n      value: \'\342\211\244 120 mg/dl\',\n      status: \'normal\',\n      message: \'Profil glikemik puasa yang sehat.\'\n    });\n  }\n\n  // 11. Resting ECG\n  if (patient.restingECG === \'ST\') {\n    score += 10;\n    riskFactors.push({\n      factor: \'Profil EKG Gelombang ST-T Abnormal\',\n      impact: \'Medium\',\n      description: \'EKG istirahat menunjukkan kelainan gelombang ST-T merupakan prediktor gangguan struktural jantung.\'\n    });\n    indicators.push({\n      name: \'EKG Istirahat\',\n      value: \'Abnormalitas Gelombang ST-T\',\n      status: \'critical\',\n      message: \'Abnormalitas listrik jantung saat istirahat menunjukkan potensi hipoksia jantung.\'\n    });\n  } else if (patient.restingECG === \'LVH\') {\n    score += 12;\n    riskFactors.push({\n      factor: \'Hipertrofi Ventrikel Kiri (LVH)\',\n      impact: \'Medium\',\n      description: \'Dinding bilik jantung kiri menebal yang ditandai oleh LVH menunjukkan beban tekanan kronis atau pembesaran jantung.\'\n    });\n    indicators.push({\n      name: \'EKG Istirahat\',\n      value: \'LVH (Regangan Bilik)\',\n      status: \'warning\',\n      message: \'Bukti adanya hipertrofi ventrikel kiri akibat beban kerja jantung tinggi yang kronis.\'\n    });\n  } else {\n    indicators.push({\n      name: \'EKG Istirahat\',\n      value: \'Normal\',\n      status: \'normal\',\n      message: \'Ritme kelistrikan jantung istirahat yang sehat dan normal.\'\n    });\n  }\n\n  // Cap the final percentage realistically\n  const finalProbability = Math.max(2, Math.min(98, score));\n\n  let riskLevel: PredictionResult[\'riskLevel\'] = \'Low\';\n  if (finalProbability >= 82) {\n    riskLevel = \'Critical\';\n  } else if (finalProbability >= 60) {\n    riskLevel = \'High\';\n  } else if (finalProbability >= 30) {\n    riskLevel = \'Moderate\';\n  }\n\n  return {\n    heartDiseaseProbability: Math.round(finalProbability),\n    riskLevel,\n    riskFactors,\n    indicators\n  };\n}"
      }
      num_matches: 1
    }
  }
}
