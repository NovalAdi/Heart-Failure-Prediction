  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { PatientRecord } from \'./types\';\nimport { getInitialDemoPatients } from \'./utils/predictor\';\nimport ManualForm from \'./components/ManualForm\';\nimport BatchProcessor from \'./components/BatchProcessor\';\nimport AnalyticsCharts from \'./components/AnalyticsCharts\';\nimport { \n  Heart, \n  Activity, \n  Sparkles, \n  Upload, \n  Database, \n  Search, \n  Trash2, \n  Download, \n  RefreshCw, \n  Clock, \n  ClipboardList, \n  Dna, \n  HeartHandshake\n} from \'lucide-react\';\n\nexport default function App() {\n  const [activeTab, setActiveTab] = useState<\'dashboard\' | \'form\' | \'batch\' | \'records\'>(\'dashboard\');\n  const [records, setRecords] = useState<PatientRecord[]>([]);\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  const [riskFilter, setRiskFilter] = useState<string>(\'All\');\n\n  // Load baseline demo records from Kaggle\n  useEffect(() => {\n    const cached = localStorage.getItem(\'cardio_workspace_records\');\n    if (cached) {\n      try {\n        setRecords(JSON.parse(cached));\n      } catch (e) {\n        console.error(\'Failed parsing cached local database, loading demo defaults\');\n        setRecords(getInitialDemoPatients());\n      }\n    } else {\n      setRecords(getInitialDemoPatients());\n    }\n  }, []);\n\n  // Sync to database cache on changes\n  const updateRecordsState = (newRecords: PatientRecord[]) => {\n    setRecords(newRecords);\n    localStorage.setItem(\'cardio_workspace_records\', JSON.stringify(newRecords));\n  };\n\n  const handleAddSingleRecord = (newRec: PatientRecord) => {\n    const updated = [newRec, ...records];\n    updateRecordsState(updated);\n  };\n\n  const handleImportBatch = (newBatch: PatientRecord[]) => {\n    const updated = [...newBatch, ...records];\n    updateRecordsState(updated);\n  };\n\n  const handleDeleteRecord = (id: string) => {\n    if (confirm(\'Are you sure you wish to delete this cardiac record?\')) {\n      const updated = records.filter(rec => rec.id !== id);\n      updateRecordsState(updated);\n    }\n  };\n\n  const handleResetToDemoDefaults = () => {\n    if (confirm(\'This will wipe any custom additions and restore the pristine 6 default Patient records modeled from Kaggle. Proceed?\')) {\n      updateRecordsState(getInitialDemoPatients());\n    }\n  };\n\n  const handleClearAllHistory = () => {\n    if (confirm(\'Are you sure you wish to clear all current database history logs? This is irreversible.\')) {\n      updateRecordsState([]);\n    }\n  };\n\n  // Convert current patient list with assessments into absolute CSV string for export!\n  const handleExportDatabaseCSV = () => {\n    if (records.length === 0) {\n      alert(\'There are currently no records inside the clinical database to export.\');\n      return;\n    }\n\n    const colHeaders = [\n      \'Name\', \'Age\', \'Sex\', \'ChestPainType\', \'RestingBP\', \'Cholesterol\', \n      \'FastingBS\', \'RestingECG\', \'MaxHR\', \'ExerciseAngina\', \'Oldpeak\', \n      \'ST_Slope\', \'HeartDiseaseProbability\', \'RiskLevel\'\n    ];\n\n    const lines = records.map(rec => {\n      const prob = rec.prediction?.heartDiseaseProbability ?? 0;\n      const rLevel = rec.prediction?.riskLevel ?? \'Low\';\n      return [\n        `\"${rec.name.replace(/\"/g, \'\"\"\')}\"`,\n        rec.age,\n        `\"${rec.sex}\"`,\n        `\"${rec.chestPainType}\"`,\n        rec.restingBP,\n        rec.cholesterol,\n        rec.fastingBS,\n        `\"${rec.restingECG}\"`,\n        rec.maxHR,\n        `\"${rec.exerciseAngina}\"`,\n        rec.oldpeak,\n        `\"${rec.stSlope}\"`,\n        prob,\n        `\"${rLevel}\"`\n      ].join(\',\');\n    });\n\n    const csvContent = \"data:text/csv;charset=utf-8,\" + [colHeaders.join(\',\'), ...lines].join(\'\\n\');\n    const encodedUri = encodeURI(csvContent);\n    const downloadAnchor = document.createElement(\'a\');\n    downloadAnchor.setAttribute(\'href\', encodedUri);\n    downloadAnchor.setAttribute(\'download\', `heart_failure_diagnostic_records_${Date.now()}.csv`);\n    document.body.appendChild(downloadAnchor);\n    downloadAnchor.click();\n    document.body.removeChild(downloadAnchor);\n  };\n\n  // Filter and Search mechanism\n  const filteredRecords = records.filter(rec => {\n    const matchesSearch = rec.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n                          rec.id.toLowerCase().includes(searchQuery.toLowerCase());\n    const matchesFilter = riskFilter === \'All\' || rec.prediction?.riskLevel === riskFilter;\n    return matchesSearch && matchesFilter;\n  });\n\n  return (\n    <div id=\"application-root\" className=\"min-h-screen bg-slate-50 text-slate-800 font-sans antialiased\">\n      \n      {/* Upper Professional Hospital Branding Header */}\n      <header id=\"clinical-masthead\" className=\"bg-white border-b border-slate-200 sticky top-0 z-50 shadow-2xs\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"flex justify-between items-center h-16\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-2 bg-gradient-to-br from-red-500 to-rose-600 rounded-xl text-white shadow-sm shadow-rose-200\">\n                <Heart className=\"w-6 h-6 animate-pulse\" />\n              </div>\n              <div>\n                <span className=\"font-extrabold text-lg text-slate-900 tracking-tight flex items-center gap-1.5\">\n                  CardioSphere AI\n                  <span className=\"bg-red-50 text-red-700 text-[10px] font-bold px-1.5 py-0.5 rounded-full border border-red-100\">\n                    Clinical v2.4\n                  </span>\n                </span>\n                <p className=\"text-xs text-slate-550 truncate max-w-[200px] sm:max-w-md\">Heart Failure Decision-Support Diagnostic Workspace</p>\n              </div>\n            </div>\n\n            {/* Quick Metrics */}\n            <div className=\"hidden md:flex items-center gap-6 text-xs text-slate-500\">\n              <div className=\"flex items-center gap-1.5\">\n                <Clock className=\"w-4 h-4 text-indigo-500\" />\n                <span>System Sync: <strong className=\"font-mono text-slate-700\">Active (UTC)</strong></span>\n              </div>\n              <div className=\"flex items-center gap-1.5\">\n                <Dna className=\"w-4 h-4 text-emerald-500\" />\n                <span>Database Status: <strong className=\"font-mono text-slate-700\">{records.length} records</strong></span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Core Platform Content container */}\n      <main className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8\" id=\"application-workspace\">\n        \n        {/* Banner Section */}\n        <div className=\"bg-gradient-to-r from-slate-900 via-indigo-950 to-slate-900 rounded-3xl p-6 sm:p-8 text-white relative overflow-hidden shadow-md\">\n          {/* Subtle medical background vector simulation */}\n          <div className=\"absolute top-0 right-0 w-80 h-80 bg-red-500/5 rounded-full blur-3xl -mr-32 -mt-32\"></div>\n          \n          <div className=\"max-w-3xl space-y-3 relative z-10\">\n            <span className=\"inline-flex items-center gap-1.5 px-3 py-1 bg-white/12 text-indigo-300 rounded-full text-[10px] font-bold uppercase tracking-wider leading-none\">\n              <HeartHandshake className=\"w-3.5 h-3.5\" />\n              Kaggle Clinical Dataset Aligned\n            </span>\n            <h1 className=\"text-2xl sm:text-3xl font-black tracking-tight leading-tight\">\n              Heart Failure Predictive Analysis & Diagnostics\n            </h1>\n            <p className=\"text-slate-300 text-xs sm:text-sm leading-relaxed max-w-2xl\">\n              Evaluate myocardial risk factors using clinical stress inputs including ST Segment Slopes, Exercise Angina, and Oldpeak values. Perform automated single-patient diagnosis or process hundreds of rows via standard medical spreadsheet uploads.\n            </p>\n          </div>\n        </div>\n\n        {/* Tabbed Navigation Workstations */}\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-slate-200 pb-2 gap-4\" id=\"navigation-bar\">\n          <nav className=\"flex space-x-1 bg-slate-100 p-1 rounded-xl w-fit\" aria-label=\"Tabs\">\n            <button\n              onClick={() => setActiveTab(\'dashboard\')}\n              id=\"tab-btn-dashboard\"\n              className={`px-4 py-2 text-xs font-semibold rounded-lg transition cursor-pointer flex items-center gap-1.5 ${\n                activeTab === \'dashboard\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-550 hover:text-slate-900 hover:bg-white/50\'\n              }`}\n            >\n              <Activity className=\"w-4 h-4 text-red-500\" />\n              Overview & Analytics\n            </button>\n            <button\n              onClick={() => setActiveTab(\'form\')}\n              id=\"tab-btn-form\"\n              className={`px-4 py-2 text-xs font-semibold rounded-lg transition cursor-pointer flex items-center gap-1.5 ${\n                activeTab === \'form\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-550 hover:text-slate-900 hover:bg-white/50\'\n              }`}\n            >\n              <Sparkles className=\"w-4 h-4 text-indigo-500\" />\n              Manual Diagnostic Form\n            </button>\n            <button\n              onClick={() => setActiveTab(\'batch\')}\n              id=\"tab-btn-batch\"\n              className={`px-4 py-2 text-xs font-semibold rounded-lg transition cursor-pointer flex items-center gap-1.5 ${\n                activeTab === \'batch\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-550 hover:text-slate-900 hover:bg-white/50\'\n              }`}\n            >\n              <Upload className=\"w-4 h-4 text-indigo-500\" />\n              Bulk CSV Processor\n            </button>\n            <button\n              onClick={() => setActiveTab(\'records\')}\n              id=\"tab-btn-records\"\n              className={`px-4 py-2 text-xs font-semibold rounded-lg transition cursor-pointer flex items-center gap-1.5 ${\n                activeTab === \'records\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-550 hover:text-slate-900 hover:bg-white/50\'\n              }`}\n            >\n              <ClipboardList className=\"w-4 h-4 text-indigo-500\" />\n              Database Records ({records.length})\n            </button>\n          </nav>\n\n          {/* Core Controls */}\n          <div className=\"flex items-center gap-2 self-start md:self-auto\" id=\"top-tier-controls\">\n            <button\n              type=\"button\"\n              id=\"btn-export-records\"\n              onClick={handleExportDatabaseCSV}\n              className=\"bg-emerald-600 hover:bg-emerald-700 text-white border border-transparent text-xs font-bold px-3 py-1.8 rounded-xl flex items-center gap-1.5 transition cursor-pointer\"\n            >\n              <Download className=\"w-4 h-4\" />\n              Export Database (CSV)\n            </button>\n            <button\n              type=\"button\"\n              id=\"btn-reset-demo\"\n              onClick={handleResetToDemoDefaults}\n              className=\"bg-white hover:bg-slate-100 text-slate-700 border border-slate-200 text-xs font-bold px-3 py-1.8 rounded-xl flex items-center gap-1.5 transition cursor-pointer\"\n              title=\"Reset Database to Pristine Kaggle Demo Records\"\n            >\n              <RefreshCw className=\"w-3.5 h-3.5 text-slate-500\" />\n              Reset Defaults\n            </button>\n          </div>\n        </div>\n\n        {/* Tab Workstations Rendering Panels */}\n        <div id=\"workspace-viewport\">\n          \n          {/* Tab Panel: Dashboard Statistics */}\n          {activeTab === \'dashboard\' && (\n            <div className=\"space-y-6\" id=\"dashboard-workstation-panel\">\n              <AnalyticsCharts records={records} />\n            </div>\n          )}\n\n          {/* Tab Panel: Individual Risk Form entry */}\n          {activeTab === \'form\' && (\n            <div id=\"form-workstation-panel\">\n              <ManualForm onAddRecord={handleAddSingleRecord} />\n            </div>\n          )}\n\n          {/* Tab Panel: Batch File Excel CSV uploader */}\n          {activeTab === \'batch\' && (\n            <div id=\"batch-workstation-panel\">\n              <BatchProcessor onImportRecords={handleImportBatch} />\n            </div>\n          )}\n\n          {/* Tab Panel: Active Database Search/Filter records list */}\n          {activeTab === \'records\' && (\n            <div className=\"space-y-6 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\" id=\"records-workstation-panel\">\n              <div className=\"border-b border-slate-100 pb-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\n                <div>\n                  <h2 className=\"text-xl font-bold text-slate-800 flex items-center gap-2\">\n                    <Database className=\"w-5 h-5 text-indigo-500\" />\n                    Patient Diagnostic History Logs\n                  </h2>\n                  <p className=\"text-sm text-slate-500 mt-1\">\n                    Search, filter, and review all assessed cardiology files currently persistent inside this workspace session.\n                  </p>\n                </div>\n                \n                {records.length > 0 && (\n                  <button\n                    type=\"button\"\n                    onClick={handleClearAllHistory}\n                    id=\"btn-clear-db\"\n                    className=\"self-start md:self-auto text-xs text-red-650 hover:text-red-700 font-bold flex items-center gap-1 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg border border-red-150 transition cursor-pointer\"\n                  >\n                    <Trash2 className=\"w-3.5 h-3.5\" />\n                    Wipe Database History\n                  </button>\n                )}\n              </div>\n\n              {/* Filtering Controls */}\n              <div className=\"flex flex-col sm:flex-row gap-3\">\n                <div className=\"flex-1 relative\">\n                  <Search className=\"w-4 h-4 text-slate-450 absolute left-3 top-1/2 -translate-y-1/2\" />\n                  <input\n                    type=\"text\"\n                    placeholder=\"Search patient names...\"\n                    value={searchQuery}\n                    onChange={(e) => setSearchQuery(e.target.value)}\n                    id=\"search-patient-input\"\n                    className=\"w-full pl-9 pr-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs\"\n                  />\n                </div>\n\n                <div className=\"flex items-center gap-2 shrink-0\">\n                  <label htmlFor=\"risk-filter-dropdown\" className=\"text-xs font-semibold text-slate-550 whitespace-nowrap\">Filter Risk:</label>\n                  <select\n                    id=\"risk-filter-dropdown\"\n                    value={riskFilter}\n                    onChange={(e) => setRiskFilter(e.target.value)}\n                    className=\"px-3 py-1.8 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs text-slate-700\"\n                  >\n                    <option value=\"All\">All Risk Levels</option>\n                    <option value=\"Low\">Low Risk</option>\n                    <option value=\"Moderate\">Moderate Risk</option>\n                    <option value=\"High\">High Risk</option>\n                    <option value=\"Critical\">Critical Risk</option>\n                  </select>\n                </div>\n              </div>\n\n              {/* Table Records List rendering */}\n              {filteredRecords.length === 0 ? (\n                <div className=\"text-center p-12 bg-slate-50 border border-slate-100 rounded-xl text-slate-500\">\n                  <p className=\"text-sm font-bold text-slate-700\">No Patient Records Match Your Parameter</p>\n                  <p className=\"text-xs text-slate-400 mt-1\">Try resetting the defaults or revising the filter/search criteria.</p>\n                </div>\n              ) : (\n                <div className=\"overflow-x-auto border border-slate-150 rounded-xl\">\n                  <table className=\"min-w-full divide-y divide-slate-150 text-left text-xs text-slate-650\" id=\"records-table\">\n                    <thead className=\"bg-slate-50 font-bold text-slate-600\">\n                      <tr>\n                        <th className=\"px-4 py-3\">Patient Name</th>\n                        <th className=\"px-3 py-3\">Age/Sex/BP</th>\n                        <th className=\"px-3 py-3\">Chest Pain</th>\n                        <th className=\"px-3 py-3 text-center\">Fasting BS</th>\n                        <th className=\"px-3 py-3 text-center font-mono\">Resting ECG</th>\n                        <th className=\"px-3 py-3 text-center\">ST Slope</th>\n                        <th className=\"px-3 py-3 text-center\">Likelihood</th>\n                        <th className=\"px-3 py-3 text-right\">Risk Tier</th>\n                        <th className=\"px-4 py-3 text-right\">Actions</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-100 bg-white\">\n                      {filteredRecords.map((rec) => {\n                        const prob = rec.prediction?.heartDiseaseProbability ?? 0;\n                        const level = rec.prediction?.riskLevel ?? \'Low\';\n                        return (\n                          <tr key={rec.id} className=\"hover:bg-slate-50/50\">\n                            <td className=\"px-4 py-3\">\n                              <span className=\"font-bold text-slate-850 block\">{rec.name}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">{rec.id}</span>\n                            </td>\n                            <td className=\"px-3 py-3 whitespace-nowrap\">\n                              {rec.age}yo / {rec.sex} ({rec.restingBP} mmHg)\n                            </td>\n                            <td className=\"px-3 py-3\">\n                              <span className=\"font-semibold block\">{rec.chestPainType}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5\">Angina: {rec.exerciseAngina}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              {rec.fastingBS === 1 ? \'Glucose High (>120)\' : \'Glucose Light\'}\n                            </td>\n                            <td className=\"px-3 py-3 text-center whitespace-nowrap font-mono\">\n                              {rec.restingECG} / {rec.maxHR}bpm\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              <span className=\"font-semibold text-slate-700 block\">{rec.stSlope}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">oldpeak: {rec.oldpeak}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center font-bold text-slate-800\">\n                              {prob}%\n                            </td>\n                            <td className=\"px-3 py-3 text-right\">\n                              <span className={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold ${\n                                level === \'Critical\' ? \'bg-red-50 text-red-700\' :\n                                level === \'High\' ? \'bg-red-50 text-orange-700\' :\n                                level === \'Moderate\' ? \'bg-yellow-50 text-yellow-700\' :\n                                \'bg-emerald-50 text-emerald-700\'\n                              }`}>\n                                {level}\n                              </span>\n                            </td>\n                            <td className=\"px-4 py-3 text-right\">\n                              <button\n                                type=\"button\"\n                                onClick={() => handleDeleteRecord(rec.id)}\n                                className=\"text-slate-400 hover:text-red-650 transition cursor-pointer\"\n                                title=\"Delete this record\"\n                              >\n                                <Trash2 className=\"w-4 h-4\" />\n                              </button>\n                            </td>\n                          </tr>\n                        );\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n          )}\n\n        </div>\n\n      </main>\n\n      {/* Corporate Educational Legal Disclaimer Footer */}\n      <footer id=\"app-disclaimer-footer\" className=\"bg-white border-t border-slate-200 py-8 text-center text-xs text-slate-400\">\n        <div className=\"max-w-7xl mx-auto px-4 space-y-2\">\n          <p className=\"font-bold text-slate-500\">Clinical & Academic Disclaimer</p>\n          <p className=\"max-w-3xl mx-auto leading-relaxed\">\n            CardioSphere AI is built strictly as an analytical decision-support training tool based on the public fedesoriano/heart-failure-prediction registry on Kaggle. It does not replace professional cardiological diagnosis, medical examination, therapy, or prescriptions. Patients must consult clinical professionals for serious cardiac evaluations.\n          </p>\n          <p className=\"pt-4 font-mono text-[10px] text-slate-350\">\n            \302\251 2026 CardioSphere Healthcare Systems. All telemetry representations powered by Gemini AI and rule-based diagnostic frameworks.\n          </p>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
