        }
        lines {
          text: "  const saveToSystem = () => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    if (!localPrediction) return;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const finalRecord: PatientRecord = {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      ...formData,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
