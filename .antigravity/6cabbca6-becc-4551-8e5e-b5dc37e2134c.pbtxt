    instruction: "Translate table headings, search inputs, filters, action triggers, and corporate medical disclaimers to Indonesian."
    replacement_infos {
      original_chunk {
        target_content: "          {/* Tab Panel: Active Database Search/Filter records list */}\n          {activeTab === \'records\' && (\n            <div className=\"space-y-6 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\" id=\"records-workstation-panel\">\n              <div className=\"border-b border-slate-100 pb-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\n                <div>\n                  <h2 className=\"text-xl font-bold text-slate-800 flex items-center gap-2\">\n                    <Database className=\"w-5 h-5 text-indigo-500\" />\n                    Patient Diagnostic History Logs\n                  </h2>\n                  <p className=\"text-sm text-slate-500 mt-1\">\n                    Search, filter, and review all assessed cardiology files currently persistent inside this workspace session.\n                  </p>\n                </div>\n                \n                {records.length > 0 && (\n                  <button\n                    type=\"button\"\n                    onClick={handleClearAllHistory}\n                    id=\"btn-clear-db\"\n                    className=\"self-start md:self-auto text-xs text-red-655 hover:text-red-700 font-bold flex items-center gap-1 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg border border-red-150 transition cursor-pointer\"\n                  >\n                    <Trash2 className=\"w-3.5 h-3.5\" />\n                    Wipe Database History\n                  </button>\n                )}\n              </div>\n\n              {/* Filtering Controls */}\n              <div className=\"flex flex-col sm:flex-row gap-3\">\n                <div className=\"flex-1 relative\">\n                  <Search className=\"w-4 h-4 text-slate-450 absolute left-3 top-1/2 -translate-y-1/2\" />\n                  <input\n                    type=\"text\"\n                    placeholder=\"Search patient names...\"\n                    value={searchQuery}\n                    onChange={(e) => setSearchQuery(e.target.value)}\n                    id=\"search-patient-input\"\n                    className=\"w-full pl-9 pr-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs\"\n                  />\n                </div>\n\n                <div className=\"flex items-center gap-2 shrink-0\">\n                  <label htmlFor=\"risk-filter-dropdown\" className=\"text-xs font-semibold text-slate-550 whitespace-nowrap\">Filter Risk:</label>\n                  <select\n                    id=\"risk-filter-dropdown\"\n                    value={riskFilter}\n                    onChange={(e) => setRiskFilter(e.target.value)}\n                    className=\"px-3 py-1.8 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs text-slate-700\"\n                  >\n                    <option value=\"All\">All Risk Levels</option>\n                    <option value=\"Low\">Low Risk</option>\n                    <option value=\"Moderate\">Moderate Risk</option>\n                    <option value=\"High\">High Risk</option>\n                    <option value=\"Critical\">Critical Risk</option>\n                  </select>\n                </div>\n              </div>\n\n              {/* Table Records List rendering */}\n              {filteredRecords.length === 0 ? (\n                <div className=\"text-center p-12 bg-slate-50 border border-slate-100 rounded-xl text-slate-500\">\n                  <p className=\"text-sm font-bold text-slate-700\">No Patient Records Match Your Parameter</p>\n                  <p className=\"text-xs text-slate-400 mt-1\">Try resetting the defaults or revising the filter/search criteria.</p>\n                </div>\n              ) : (\n                <div className=\"overflow-x-auto border border-slate-150 rounded-xl\">\n                  <table className=\"min-w-full divide-y divide-slate-150 text-left text-xs text-slate-650\" id=\"records-table\">\n                    <thead className=\"bg-slate-50 font-bold text-slate-600\">\n                      <tr>\n                        <th className=\"px-4 py-3\">Patient Name</th>\n                        <th className=\"px-3 py-3\">Age/Sex/BP</th>\n                        <th className=\"px-3 py-3\">Chest Pain</th>\n                        <th className=\"px-3 py-3 text-center\">Fasting BS</th>\n                        <th className=\"px-3 py-3 text-center font-mono\">Resting ECG</th>\n                        <th className=\"px-3 py-3 text-center\">ST Slope</th>\n                        <th className=\"px-3 py-3 text-center\">Likelihood</th>\n                        <th className=\"px-3 py-3 text-right\">Risk Tier</th>\n                        <th className=\"px-4 py-3 text-right\">Actions</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-100 bg-white\">\n                      {filteredRecords.map((rec) => {\n                        const prob = rec.prediction?.heartDiseaseProbability ?? 0;\n                        const level = rec.prediction?.riskLevel ?? \'Low\';\n                        return (\n                          <tr key={rec.id} className=\"hover:bg-slate-50/50\">\n                            <td className=\"px-4 py-3\">\n                              <span className=\"font-bold text-slate-850 block\">{rec.name}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">{rec.id}</span>\n                            </td>\n                            <td className=\"px-3 py-3 whitespace-nowrap\">\n                              {rec.age}yo / {rec.sex} ({rec.restingBP} mmHg)\n                            </td>\n                            <td className=\"px-3 py-3\">\n                              <span className=\"font-semibold block\">{rec.chestPainType}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5\">Angina: {rec.exerciseAngina}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              {rec.fastingBS === 1 ? \'Glucose High (>120)\' : \'Glucose Light\'}\n                            </td>\n                            <td className=\"px-3 py-3 text-center whitespace-nowrap font-mono\">\n                              {rec.restingECG} / {rec.maxHR}bpm\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              <span className=\"font-semibold text-slate-700 block\">{rec.stSlope}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">oldpeak: {rec.oldpeak}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center font-bold text-slate-800\">\n                              {prob}%\n                            </td>\n                            <td className=\"px-3 py-3 text-right\">\n                              <span className={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold ${\n                                level === \'Critical\' ? \'bg-red-50 text-red-700\' :\n                                level === \'High\' ? \'bg-red-50 text-orange-700\' :\n                                level === \'Moderate\' ? \'bg-yellow-50 text-yellow-700\' :\n                                \'bg-emerald-50 text-emerald-700\'\n                              }`}>\n                                {level}\n                              </span>\n                            </td>\n                            <td className=\"px-4 py-3 text-right\">\n                              <button\n                                type=\"button\"\n                                onClick={() => handleDeleteRecord(rec.id)}\n                                className=\"text-slate-400 hover:text-red-650 transition cursor-pointer\"\n                                title=\"Delete this record\"\n                              >\n                                <Trash2 className=\"w-4 h-4\" />\n                              </button>\n                            </td>\n                          </tr>\n                        );\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n          )}\n\n        </div>\n\n      </main>\n\n      {/* Corporate Educational Legal Disclaimer Footer */}\n      <footer id=\"app-disclaimer-footer\" className=\"bg-white border-t border-slate-200 py-8 text-center text-xs text-slate-400\">\n        <div className=\"max-w-7xl mx-auto px-4 space-y-2\">\n          <p className=\"font-bold text-slate-500\">Clinical & Academic Disclaimer</p>\n          <p className=\"max-w-3xl mx-auto leading-relaxed\">\n            CardioSphere AI is built strictly as an analytical decision-support training tool based on the public fedesoriano/heart-failure-prediction registry on Kaggle. It does not replace professional cardiological diagnosis, medical examination, therapy, or prescriptions. Patients must consult clinical professionals for serious cardiac evaluations.\n          </p>\n          <p className=\"pt-4 font-mono text-[10px] text-slate-350\">\n            \302\251 2026 CardioSphere Healthcare Systems. All telemetry representations powered by Gemini AI and rule-based diagnostic frameworks.\n          </p>\n        </div>\n      </footer>"
        replacement_content: "          {/* Tab Panel: Active Database Search/Filter records list */}\n          {activeTab === \'records\' && (\n            <div className=\"space-y-6 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\" id=\"records-workstation-panel\">\n              <div className=\"border-b border-slate-100 pb-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\n                <div>\n                  <h2 className=\"text-xl font-bold text-slate-800 flex items-center gap-2\">\n                    <Database className=\"w-5 h-5 text-indigo-500\" />\n                    Riwayat Diagnostik Rekam Medis Pasien\n                  </h2>\n                  <p className=\"text-sm text-slate-500 mt-1 pb-1\">\n                    Cari, saring, dan tinjau semua berkas rekam medis kardiologi yang dinilai dan tersimpan dalam sesi simulasi ini.\n                  </p>\n                </div>\n                \n                {records.length > 0 && (\n                  <button\n                    type=\"button\"\n                    onClick={handleClearAllHistory}\n                    id=\"btn-clear-db\"\n                    className=\"self-start md:self-auto text-xs text-red-655 hover:text-red-700 font-bold flex items-center gap-1 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg border border-red-150 transition cursor-pointer\"\n                  >\n                    <Trash2 className=\"w-3.5 h-3.5\" />\n                    Kosongkan Semua Riwayat\n                  </button>\n                )}\n              </div>\n\n              {/* Filtering Controls */}\n              <div className=\"flex flex-col sm:flex-row gap-3\">\n                <div className=\"flex-1 relative\">\n                  <Search className=\"w-4 h-4 text-slate-450 absolute left-3 top-1/2 -translate-y-1/2\" />\n                  <input\n                    type=\"text\"\n                    placeholder=\"Cari nama pasien...\"\n                    value={searchQuery}\n                    onChange={(e) => setSearchQuery(e.target.value)}\n                    id=\"search-patient-input\"\n                    className=\"w-full pl-9 pr-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs font-semibold\"\n                  />\n                </div>\n\n                <div className=\"flex items-center gap-2 shrink-0\">\n                  <label htmlFor=\"risk-filter-dropdown\" className=\"text-xs font-semibold text-slate-550 whitespace-nowrap\">Saring Risiko:</label>\n                  <select\n                    id=\"risk-filter-dropdown\"\n                    value={riskFilter}\n                    onChange={(e) => setRiskFilter(e.target.value)}\n                    className=\"px-3 py-1.8 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-xs text-slate-700 font-semibold\"\n                  >\n                    <option value=\"All\">Semua Tingkat Risiko</option>\n                    <option value=\"Low\">Risiko Rendah</option>\n                    <option value=\"Moderate\">Risiko Sedang</option>\n                    <option value=\"High\">Risiko Tinggi</option>\n                    <option value=\"Critical\">Risiko Kritis</option>\n                  </select>\n                </div>\n              </div>\n\n              {/* Table Records List rendering */}\n              {filteredRecords.length === 0 ? (\n                <div className=\"text-center p-12 bg-slate-50 border border-slate-100 rounded-xl text-slate-500\">\n                  <p className=\"text-sm font-bold text-slate-700\">Tidak Ada Rekam Medis Pasien yang Cocok</p>\n                  <p className=\"text-xs text-slate-400 mt-1\">Coba atur ulang ke default atau periksa kembali filter/kriteria pencarian Anda.</p>\n                </div>\n              ) : (\n                <div className=\"overflow-x-auto border border-slate-150 rounded-xl\">\n                  <table className=\"min-w-full divide-y divide-slate-150 text-left text-xs text-slate-650\" id=\"records-table\">\n                    <thead className=\"bg-slate-50 font-bold text-slate-600\">\n                      <tr>\n                        <th className=\"px-4 py-3\">Nama Pasien</th>\n                        <th className=\"px-3 py-3\">Usia/Gender/TD</th>\n                        <th className=\"px-3 py-3\">Nyeri Dada</th>\n                        <th className=\"px-3 py-3 text-center\">Gula Darah Puasa</th>\n                        <th className=\"px-3 py-3 text-center font-mono\">EKG Istirahat</th>\n                        <th className=\"px-3 py-3 text-center\">Kelandaian ST</th>\n                        <th className=\"px-3 py-3 text-center\">Probabilitas</th>\n                        <th className=\"px-3 py-3 text-right\">Risiko</th>\n                        <th className=\"px-4 py-3 text-right\">Aksi</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-100 bg-white\">\n                      {filteredRecords.map((rec) => {\n                        const prob = rec.prediction?.heartDiseaseProbability ?? 0;\n                        const level = rec.prediction?.riskLevel ?? \'Low\';\n                        return (\n                          <tr key={rec.id} className=\"hover:bg-slate-50/50\">\n                            <td className=\"px-4 py-3\">\n                              <span className=\"font-bold text-slate-850 block\">{rec.name}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">{rec.id}</span>\n                            </td>\n                            <td className=\"px-3 py-3 whitespace-nowrap\">\n                              {rec.age} thn / {rec.sex === \'M\' ? \'Pria\' : \'Wanita\'} ({rec.restingBP} mmHg)\n                            </td>\n                            <td className=\"px-3 py-3\">\n                              <span className=\"font-semibold block\">{rec.chestPainType}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5\">Angina Latihan: {rec.exerciseAngina === \'Y\' ? \'Ya\' : \'Tidak\'}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              {rec.fastingBS === 1 ? \'Tinggi (>120 mg/dl)\' : \'Normal\'}\n                            </td>\n                            <td className=\"px-3 py-3 text-center whitespace-nowrap font-mono\">\n                              {rec.restingECG} / {rec.maxHR} bpm\n                            </td>\n                            <td className=\"px-3 py-3 text-center\">\n                              <span className=\"font-semibold text-slate-700 block\">{rec.stSlope}</span>\n                              <span className=\"text-[10px] text-slate-400 block mt-0.5 font-mono\">oldpeak: {rec.oldpeak}</span>\n                            </td>\n                            <td className=\"px-3 py-3 text-center font-bold text-slate-800\">\n                              {prob}%\n                            </td>\n                            <td className=\"px-3 py-3 text-right\">\n                              <span className={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold ${\n                                level === \'Critical\' ? \'bg-red-50 text-red-700\' :\n                                level === \'High\' ? \'bg-red-50 text-orange-705\' :\n                                level === \'Moderate\' ? \'bg-yellow-50 text-yellow-705\' :\n                                \'bg-emerald-50 text-emerald-700\'\n                              }`}>\n                                {level === \'Critical\' ? \'Risiko Kritis\' :\n                                 level === \'High\' ? \'Risiko Tinggi\' :\n                                 level === \'Moderate\' ? \'Risiko Sedang\' :\n                                 \'Risiko Rendah\'}\n                              </span>\n                            </td>\n                            <td className=\"px-4 py-3 text-right\">\n                              <button\n                                type=\"button\"\n                                onClick={() => handleDeleteRecord(rec.id)}\n                                className=\"text-slate-400 hover:text-red-650 transition cursor-pointer\"\n                                title=\"Hapus catatan ini\"\n                              >\n                                <Trash2 className=\"w-4 h-4\" />\n                              </button>\n                            </td>\n                          </tr>\n                        );\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n          )}\n\n        </div>\n\n      </main>\n\n      {/* Corporate Educational Legal Disclaimer Footer */}\n      <footer id=\"app-disclaimer-footer\" className=\"bg-white border-t border-slate-200 py-8 text-center text-xs text-slate-400\">\n        <div className=\"max-w-7xl mx-auto px-4 space-y-2\">\n          <p className=\"font-bold text-slate-500\">Pernyataan Penyangkalan Klinis & Akademis</p>\n          <p className=\"max-w-3xl mx-auto leading-relaxed\">\n            CardioSphere AI didesain murni sebagai alat bantu analisis kualitatif dan edukasi klinis berdasarkan dataset publik fedesoriano/heart-failure-prediction di Kaggle. Aplikasi ini tidak menggantikan diagnosis profesional dokter spesialis jantung, pemeriksaan medis langsung, penentuan terapi, atau pemberian resep obat. Pasien wajib berkonsultasi dengan profesional medis kardiologi untuk evaluasi jantung yang akurat.\n          </p>\n          <p className=\"pt-4 font-mono text-[10px] text-slate-350\">\n            \302\251 2026 CardioSphere Healthcare Systems. Semua representasi interpretasi ditenagai oleh Gemini AI dan sistem penilaian diagnostik klinis rule-based.\n          </p>\n        </div>\n      </footer>"
